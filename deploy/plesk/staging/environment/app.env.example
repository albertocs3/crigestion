# Install as /etc/crigestion-staging/app.env (root:crigestion-staging, mode 0640).
NODE_ENV=production
APP_ENV=staging
APP_BASE_URL=https://gestion-test.crisoft.es
TRUST_PROXY_HEADERS=true

DATABASE_URL=postgresql://crigestion_staging_app:CHANGE_ME@127.0.0.1:5432/crigestion_staging?schema=public
APP_SESSION_SECRET=CHANGE_ME_32_OR_MORE_RANDOM_CHARACTERS
AUTH_COOKIE_NAME=crigestion_staging_session
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=lax
VERIFACTU_CREDENTIAL_IDEMPOTENCY_SECRET=CHANGE_ME_DISTINCT_32_OR_MORE_RANDOM_CHARACTERS

# Start closed. Enable only after initialization and credential import.
VERIFACTU_ENABLED=false
VERIFACTU_ENVIRONMENT=TEST
VERIFACTU_ALLOW_PRODUCTION=false
VERIFACTU_PRODUCTION_RELEASE_ID=
VERIFACTU_WORKER_ENVIRONMENT=TEST
VERIFACTU_WORKER_ALLOW_PRODUCTION=false

VERIFACTU_CREDENTIAL_ACTIVE_KEY_ID=CHANGE_ME_KEY_ID
VERIFACTU_CREDENTIAL_KEYS='{"CHANGE_ME_KEY_ID":"CHANGE_ME_AES_256_BASE64"}'
VERIFACTU_PAYLOAD_ACTIVE_KEY_ID=CHANGE_ME_PAYLOAD_KEY_ID
VERIFACTU_PAYLOAD_KEYS='{"CHANGE_ME_PAYLOAD_KEY_ID":"CHANGE_ME_AES_256_BASE64"}'

# Internal application backup queue. This does not configure the PostgreSQL
# timer that writes /root/crigestion-staging-backups.
BACKUP_AUTO_PROCESS=false
BACKUP_DIRECTORY=/var/lib/crigestion-staging/backups
