# Install as /etc/crigestion-staging/migrator.env (root:crigestion-staging-migrator, mode 0640).
NODE_ENV=production
APP_ENV=staging
DATABASE_URL=postgresql://crigestion_staging_migrator:CHANGE_ME@127.0.0.1:5432/crigestion_staging?schema=public
CRIGESTION_MIGRATION_EXPECTED_DATABASE=crigestion_staging
CRIGESTION_RUNTIME_DATABASE_ROLE=crigestion_staging_app
CRIGESTION_MIGRATION_CONFIRM_STAGING=CRIGESTION_STAGING_MIGRATION_AUTHORIZED
