# Install as /etc/crigestion-staging/build.env (root:root, mode 0600).
NODE_ENV=production
APP_ENV=staging
APP_BASE_URL=https://gestion-test.crisoft.es
DATABASE_URL=postgresql://build_only:build_only@127.0.0.1:5432/crigestion_staging?schema=public
APP_SESSION_SECRET=build-only-placeholder-at-least-32-characters
VERIFACTU_CREDENTIAL_IDEMPOTENCY_SECRET=build-only-distinct-placeholder-32-characters
AUTH_COOKIE_SECURE=true
TRUST_PROXY_HEADERS=true
VERIFACTU_ENABLED=false
VERIFACTU_ENVIRONMENT=TEST
VERIFACTU_WORKER_ENVIRONMENT=TEST
VERIFACTU_ALLOW_PRODUCTION=false
VERIFACTU_WORKER_ALLOW_PRODUCTION=false
