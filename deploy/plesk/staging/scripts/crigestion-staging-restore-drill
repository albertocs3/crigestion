#!/bin/bash
set -euo pipefail

umask 077

BACKUP_DIR='/root/crigestion-staging-backups'
ACTIVE_DB='crigestion_staging'
PG_BIN_DIR='/usr/lib/postgresql/14/bin'
BACKUP="${1:-}"
DRILL_DB="crigestion_restore_drill_$(date -u +%Y%m%dt%H%M%Sz)"
CREATED=0

unset \
  PGHOST \
  PGHOSTADDR \
  PGPORT \
  PGDATABASE \
  PGUSER \
  PGSERVICE \
  PGSERVICEFILE \
  PGOPTIONS

guard_drill_database() {
  [[ "$DRILL_DB" =~ ^crigestion_restore_drill_[0-9]{8}t[0-9]{6}z$ ]]
  [ "$DRILL_DB" != "$ACTIVE_DB" ]
}

cleanup() {
  local drop_exit=0

  if [ "$CREATED" -eq 1 ] && guard_drill_database; then
    set +e

    runuser -u postgres -- "$PG_BIN_DIR/psql" \
      -X -v ON_ERROR_STOP=1 -d postgres \
      -c "ALTER DATABASE \"$DRILL_DB\" ALLOW_CONNECTIONS false;" \
      > /dev/null

    runuser -u postgres -- "$PG_BIN_DIR/psql" \
      -X -v ON_ERROR_STOP=1 -d postgres \
      -c "SELECT pg_terminate_backend(pid)
          FROM pg_stat_activity
          WHERE datname = '$DRILL_DB'
            AND pid <> pg_backend_pid();" \
      > /dev/null

    runuser -u postgres -- "$PG_BIN_DIR/dropdb" \
      --if-exists "$DRILL_DB"

    drop_exit=$?
    set -e

    if [ "$drop_exit" -eq 0 ]; then
      CREATED=0
    fi
  fi

  return "$drop_exit"
}

on_exit() {
  local original_exit=$?

  trap - EXIT

  if ! cleanup; then
    echo "RESTORE_DRILL_CLEANUP_FAILED database=$DRILL_DB" >&2

    if [ "$original_exit" -eq 0 ]; then
      original_exit=1
    fi
  fi

  exit "$original_exit"
}

trap on_exit EXIT

guard_drill_database

if [ -z "$BACKUP" ]; then
  BACKUP="$(
    find "$BACKUP_DIR" \
      -maxdepth 1 \
      -type f \
      -name 'crigestion_staging-auto-*.dump' \
      -printf '%T@ %p\n' |
    sort -nr |
    head -n 1 |
    cut -d' ' -f2-
  )"
fi

test -n "$BACKUP"
BACKUP="$(readlink -f -- "$BACKUP")"
BACKUP_NAME="$(basename -- "$BACKUP")"

if [ "$(dirname -- "$BACKUP")" != "$BACKUP_DIR" ] || ! [[
  "$BACKUP_NAME" =~ ^crigestion_staging-auto-[0-9]{8}T[0-9]{6}Z\.dump$
]]; then
  echo 'RESTORE_DRILL_BACKUP_PATH_INVALID' >&2
  exit 1
fi

test -f "$BACKUP"
test -f "$BACKUP.sha256"

echo "RESTORE_DRILL_DATABASE=$DRILL_DB"
echo "RESTORE_DRILL_BACKUP=$BACKUP"

(
  cd "$BACKUP_DIR"
  /usr/bin/sha256sum -c "$(basename "$BACKUP").sha256"
)

"$PG_BIN_DIR/pg_restore" --list "$BACKUP" > /dev/null

DB_EXISTS="$(
  runuser -u postgres -- "$PG_BIN_DIR/psql" \
    -X -d postgres -Atqc \
    "SELECT 1 FROM pg_database WHERE datname = '$DRILL_DB';"
)"

test -z "$DB_EXISTS"

runuser -u postgres -- "$PG_BIN_DIR/psql" \
  -X -v ON_ERROR_STOP=1 -d postgres <<SQL
CREATE DATABASE "$DRILL_DB"
  WITH TEMPLATE template0
       ENCODING 'UTF8'
       ALLOW_CONNECTIONS false;
SQL

CREATED=1

runuser -u postgres -- "$PG_BIN_DIR/psql" \
  -X -v ON_ERROR_STOP=1 -d postgres <<SQL
REVOKE CONNECT ON DATABASE "$DRILL_DB" FROM PUBLIC;
GRANT CREATE ON DATABASE "$DRILL_DB" TO crigestion_staging_migrator;
ALTER DATABASE "$DRILL_DB" ALLOW_CONNECTIONS true;
SQL

runuser -u postgres -- "$PG_BIN_DIR/pg_restore" \
  --exit-on-error \
  --single-transaction \
  --no-owner \
  --no-privileges \
  --role=crigestion_staging_migrator \
  --dbname="$DRILL_DB" \
  < "$BACKUP"

runuser -u postgres -- "$PG_BIN_DIR/psql" \
  -X -v ON_ERROR_STOP=1 -d postgres <<SQL
REVOKE ALL PRIVILEGES ON DATABASE "$DRILL_DB"
  FROM crigestion_staging_migrator;
SQL

SUMMARY_SQL="
SELECT concat_ws(
  '|',
  (SELECT count(*) FROM pg_tables WHERE schemaname = 'public'),
  (SELECT count(*) FROM pg_sequences WHERE schemaname = 'public'),
  (SELECT count(*) FROM pg_indexes WHERE schemaname = 'public'),
  (
    SELECT count(*)
    FROM pg_constraint c
    JOIN pg_namespace n ON n.oid = c.connamespace
    WHERE n.nspname = 'public'
  ),
  (SELECT count(*) FROM public._prisma_migrations),
  (
    SELECT count(*)
    FROM public._prisma_migrations
    WHERE finished_at IS NULL
      AND rolled_back_at IS NULL
  ),
  (SELECT count(*) FROM pg_extension WHERE extname = 'btree_gist')
);
"

DRILL_SUMMARY="$(
  runuser -u postgres -- "$PG_BIN_DIR/psql" \
    -X -d "$DRILL_DB" -Atqc "$SUMMARY_SQL"
)"

echo "DRILL_SUMMARY=$DRILL_SUMMARY"

IFS='|' read -r \
  TABLE_COUNT \
  SEQUENCE_COUNT \
  INDEX_COUNT \
  CONSTRAINT_COUNT \
  MIGRATION_COUNT \
  INCOMPLETE_MIGRATION_COUNT \
  BTREE_GIST_COUNT \
  <<< "$DRILL_SUMMARY"

test "$TABLE_COUNT" -gt 0
test "$SEQUENCE_COUNT" -gt 0
test "$INDEX_COUNT" -gt 0
test "$CONSTRAINT_COUNT" -gt 0
test "$MIGRATION_COUNT" -gt 0
test "$INCOMPLETE_MIGRATION_COUNT" = '0'
test "$BTREE_GIST_COUNT" = '1'

INCOMPLETE_MIGRATIONS="$(
  runuser -u postgres -- "$PG_BIN_DIR/psql" \
    -X -d "$DRILL_DB" -Atqc \
    "SELECT count(*)
     FROM public._prisma_migrations
     WHERE finished_at IS NULL
       AND rolled_back_at IS NULL;"
)"

test "$INCOMPLETE_MIGRATIONS" = '0'

CONNECT_PRIVILEGES="$(
  runuser -u postgres -- "$PG_BIN_DIR/psql" \
    -X -d postgres -AtF'|' -c \
    "SELECT
       has_database_privilege(
         'crigestion_staging_app',
         '$DRILL_DB',
         'CONNECT'
       ),
       has_database_privilege(
         'crigestion_staging_migrator',
         '$DRILL_DB',
         'CONNECT'
       ),
       has_database_privilege(
         'crigestion_staging_migrator',
         '$DRILL_DB',
         'CREATE'
       );"
)"

echo "RUNTIME_CONNECT_PRIVILEGES=$CONNECT_PRIVILEGES"
test "$CONNECT_PRIVILEGES" = 'f|f|f'

cleanup
trap - EXIT

DB_REMAINS="$(
  runuser -u postgres -- "$PG_BIN_DIR/psql" \
    -X -d postgres -Atqc \
    "SELECT 1 FROM pg_database WHERE datname = '$DRILL_DB';"
)"

test -z "$DB_REMAINS"

systemctl is-active --quiet crigestion-staging-app.service
systemctl is-active --quiet crigestion-staging-verifactu-worker.service

/usr/bin/curl \
  --silent \
  --show-error \
  --fail \
  --max-time 15 \
  http://127.0.0.1:3101/api/health \
  > /dev/null

echo 'RESTORE_DRILL_OK'
