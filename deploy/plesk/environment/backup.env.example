# Install as /etc/crigestion/backup.env (root:crigestion-backup, mode 0640).
NODE_ENV=production
APP_ENV=production
DATABASE_URL=postgresql://crigestion_backup:CHANGE_ME@127.0.0.1:5432/crigestion_prod?schema=public
BACKUP_DIRECTORY=/var/lib/crigestion/backups
BACKUP_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_BASE64_OR_64_HEX
PG_DUMP_BINARY=/usr/bin/pg_dump
BACKUP_RUNNING_TIMEOUT_MINUTES=720
