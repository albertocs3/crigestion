# Install as /etc/crigestion/migrator.env (root:crigestion-migrator, mode 0640).
# This role owns the application schema and is used only by the one-shot unit.
DATABASE_URL=postgresql://crigestion_migrator:CHANGE_ME@127.0.0.1:5432/crigestion_prod?schema=public
APP_ENV=production
CRIGESTION_MIGRATION_EXPECTED_DATABASE=crigestion_prod
CRIGESTION_MIGRATION_CONFIRM_PRODUCTION=CRIGESTION_PRODUCTION_MIGRATION_AUTHORIZED
