# Install as /etc/crigestion/verifactu-worker.env
# (root:crigestion-verifactu, mode 0640).
# This template is deliberately unable to send to AEAT production.
NODE_ENV=production
APP_ENV=production
DATABASE_URL=postgresql://crigestion_app:CHANGE_ME@127.0.0.1:5432/crigestion_prod?schema=public

VERIFACTU_ENABLED=false
VERIFACTU_ENVIRONMENT=PRODUCTION
VERIFACTU_ALLOW_PRODUCTION=false
VERIFACTU_PRODUCTION_RELEASE_ID=
VERIFACTU_WORKER_ENVIRONMENT=PRODUCTION
VERIFACTU_WORKER_ALLOW_PRODUCTION=false
VERIFACTU_WORKER_PRODUCTION_CONFIRM=
VERIFACTU_WORKER_EXPECTED_DATABASE=crigestion_prod
VERIFACTU_WORKER_DEPLOYMENT_ID=plesk-primary
VERIFACTU_WORKER_POLL_MS=2000
VERIFACTU_WORKER_HEARTBEAT_MS=5000
VERIFACTU_WORKER_LEASE_MS=90000
VERIFACTU_WORKER_HEALTH_STALE_SECONDS=180

VERIFACTU_PAYLOAD_ACTIVE_KEY_ID=CHANGE_ME_PAYLOAD_KEY_ID
VERIFACTU_PAYLOAD_KEYS='{"CHANGE_ME_PAYLOAD_KEY_ID":"CHANGE_ME_AES_256_BASE64"}'
VERIFACTU_CREDENTIAL_ACTIVE_KEY_ID=CHANGE_ME_CREDENTIAL_KEY_ID
VERIFACTU_CREDENTIAL_KEYS='{"CHANGE_ME_CREDENTIAL_KEY_ID":"CHANGE_ME_AES_256_BASE64"}'
VERIFACTU_RESPONSE_ACTIVE_KEY_ID=CHANGE_ME_RESPONSE_KEY_ID
VERIFACTU_RESPONSE_KEYS='{"CHANGE_ME_RESPONSE_KEY_ID":"CHANGE_ME_AES_256_BASE64"}'
