# Install as /etc/crigestion/app.env (root:crigestion, mode 0640).
# Replace every CHANGE_ME value. Never commit the resulting file.
NODE_ENV=production
APP_ENV=production
APP_BASE_URL=https://gestion.crisoft.es
TRUST_PROXY_HEADERS=true

DATABASE_URL=postgresql://crigestion_app:CHANGE_ME@127.0.0.1:5432/crigestion_prod?schema=public
APP_SESSION_SECRET=CHANGE_ME_32_OR_MORE_RANDOM_CHARACTERS
AUTH_COOKIE_NAME=crigestion_session
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=lax
VERIFACTU_CREDENTIAL_IDEMPOTENCY_SECRET=CHANGE_ME_DISTINCT_32_OR_MORE_RANDOM_CHARACTERS

# Closed production state. Do not change these values for the initial deployment.
VERIFACTU_ENABLED=false
VERIFACTU_ENVIRONMENT=PRODUCTION
VERIFACTU_ALLOW_PRODUCTION=false
VERIFACTU_PRODUCTION_RELEASE_ID=
VERIFACTU_WORKER_ENVIRONMENT=PRODUCTION
VERIFACTU_WORKER_ALLOW_PRODUCTION=false

# Temporary TFM demo profile (never combine with any production authorization):
# VERIFACTU_TFM_DEMO_CONFIRM=TFM_DEMO_AEAT_TEST_ONLY
# VERIFACTU_ENVIRONMENT=TEST
# VERIFACTU_WORKER_ENVIRONMENT=TEST
# VERIFACTU_WORKER_PRODUCTION_CONFIRM=
# VERIFACTU_WORKER_EXPECTED_DATABASE=crigestion_prod

# The web process can import and manage credentials, so it needs the credential keyring.
VERIFACTU_CREDENTIAL_ACTIVE_KEY_ID=CHANGE_ME_KEY_ID
VERIFACTU_CREDENTIAL_KEYS='{"CHANGE_ME_KEY_ID":"CHANGE_ME_AES_256_BASE64"}'
VERIFACTU_PAYLOAD_ACTIVE_KEY_ID=CHANGE_ME_PAYLOAD_KEY_ID
VERIFACTU_PAYLOAD_KEYS='{"CHANGE_ME_PAYLOAD_KEY_ID":"CHANGE_ME_AES_256_BASE64"}'

# Backups are processed by a separate account. Do not put restore credentials here.
BACKUP_AUTO_PROCESS=false
BACKUP_DIRECTORY=/var/lib/crigestion/backups
