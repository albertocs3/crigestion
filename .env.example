DATABASE_URL="postgresql://crigestion:crigestion@localhost:5432/crigestion?schema=public"
APP_BASE_URL="http://localhost:3000"
APP_ENV="development"
TRUST_PROXY_HEADERS="false"

# Generate with: openssl rand -base64 32
APP_SESSION_SECRET="change-me-in-local-env"

# Cookies must be secure in production HTTPS.
AUTH_COOKIE_NAME="crigestion_session"
AUTH_COOKIE_SECURE="false"
AUTH_COOKIE_SAME_SITE="lax"

# VeriFactu placeholders. Do not commit real certificate paths or passwords.
VERIFACTU_ENABLED="false"
VERIFACTU_ENVIRONMENT="test"
# Application-side gate for preparing fiscal records against AEAT production.
VERIFACTU_ALLOW_PRODUCTION="false"
VERIFACTU_PRODUCTION_RELEASE_ID=""
VERIFACTU_WORKER_ENVIRONMENT="TEST"
# Must remain false unless a separately reviewed production rollout is authorized.
VERIFACTU_WORKER_ALLOW_PRODUCTION="false"
# Third production gate. Set only in the supervised worker environment after
# completing and recording the production release authorization.
VERIFACTU_WORKER_PRODUCTION_CONFIRM=""
VERIFACTU_WORKER_POLL_MS="2000"
VERIFACTU_WORKER_HEARTBEAT_MS="5000"
VERIFACTU_WORKER_LEASE_MS="90000"
VERIFACTU_WORKER_DEPLOYMENT_ID="host"
VERIFACTU_WORKER_EXPECTED_DATABASE="crigestion"
VERIFACTU_WORKER_HEALTH_STALE_SECONDS="180"
# Generate with: openssl rand -base64 32
VERIFACTU_PAYLOAD_ACTIVE_KEY_ID=""
# JSON keyring. Keep historical keys until every retained payload has been re-encrypted.
VERIFACTU_PAYLOAD_KEYS='{}'
VERIFACTU_CREDENTIAL_ACTIVE_KEY_ID=""
# JSON de claves AES-256 base64; conservar claves historicas mientras existan certificados cifrados.
VERIFACTU_CREDENTIAL_KEYS='{}'
# Secreto estable (minimo 32 caracteres), separado de sesiones y conservado durante toda la retencion idempotente.
VERIFACTU_CREDENTIAL_IDEMPOTENCY_SECRET=""
VERIFACTU_RESPONSE_ACTIVE_KEY_ID=""
# Keyring distinto del usado para certificados y payloads de solicitud.
VERIFACTU_RESPONSE_KEYS='{}'
# Diagnostico manual contra el portal TEST. Mantener desactivado por defecto y
# seleccionar siempre un registro fiscal concreto de la empresa autorizada.
VERIFACTU_AEAT_PROBE_ENABLED="false"
VERIFACTU_AEAT_PROBE_RECORD_ID=""
# Opt-in smoke externo: verifica evidencia local ALTA/ANULACION y consulta Anulado en AEAT TEST.
VERIFACTU_AEAT_TEST_CYCLE_ENABLED="false"
VERIFACTU_AEAT_TEST_CYCLE_CONFIRM=""
VERIFACTU_AEAT_TEST_CYCLE_EXPECTED_DATABASE=""
VERIFACTU_AEAT_TEST_CYCLE_INVOICE_ID=""
VERIFACTU_AEAT_TEST_CYCLE_EXPECTED_INVOICE_NUMBER=""
VERIFACTU_AEAT_TEST_CYCLE_EXPECTED_COMPANY_ID=""
VERIFACTU_AEAT_TEST_CYCLE_EXPECTED_SIF_INSTALLATION_ID=""
VERIFACTU_AEAT_TEST_CYCLE_EXPECTED_CANCELLATION_ID=""
VERIFACTU_AEAT_TEST_CYCLE_OPERATOR_ID=""
VERIFACTU_AEAT_TEST_CYCLE_RELEASE_ID=""

# Backups. Use a real 32-byte key outside source control in each environment.
BACKUP_DIRECTORY="backups"
BACKUP_ENCRYPTION_KEY=""
PG_DUMP_BINARY="pg_dump"

# Defaults to true in development, false in test, and false in production
# unless explicitly set to "true".
BACKUP_AUTO_PROCESS=""

# Restore apply. In development the app can fall back to DATABASE_URL; in
# production set RESTORE_TARGET_DATABASE_URL explicitly.
PG_RESTORE_BINARY="pg_restore"
RESTORE_TARGET_DATABASE_URL=""
