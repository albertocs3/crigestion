  total       Decimal @db.Decimal(12, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@unique([invoiceId, taxRateCode, taxRate])
  @@map("invoice_tax_summaries")
}

model InvoiceDueDate {
