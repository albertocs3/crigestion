generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InstallationStatus {
  NOT_INITIALIZED
  INITIALIZING
  INITIALIZED
  FAILED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum BackupOperationStatus {
  REQUESTED
  RUNNING
  VERIFIED
  FAILED
}

enum RestoreOperationStatus {
  REQUESTED
  VALIDATING
  VALIDATED
  PREPARING
  RESTORING
  VERIFYING
  COMPLETED
  FAILED
  REQUIRES_RECOVERY
}

enum PlatformMaintenanceMode {
  RESTORE
}

enum CustomerType {
  COMPANY
  SELF_EMPLOYED
  INDIVIDUAL
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum CustomerFiscalTreatment {
  DOMESTIC
  EU
  EXPORT
  CANARY_CEUTA_MELILLA
}

enum CustomerPaymentMethod {
  BANK_TRANSFER
  CASH
  DIRECT_DEBIT
}

enum CustomerPaymentTermsType {
  IMMEDIATE
  DAYS
  FIXED_DAY_OF_MONTH
}

enum CustomerSepaMandateStatus {
  ACTIVE
  REVOKED
  INVALIDATED
}

enum CustomerAddressType {
  BILLING
  SHIPPING
  OTHER
}

enum CustomerAddressStatus {
  ACTIVE
  INACTIVE
}

enum CatalogItemKind {
  PRODUCT
  SERVICE
  SOFTWARE
  LICENSE
}

enum CatalogItemStatus {
  ACTIVE
  INACTIVE
}

enum CatalogCategoryStatus {
  ACTIVE
  INACTIVE
}

enum CatalogTaxRateStatus {
  ACTIVE
  INACTIVE
}

enum CatalogStockMovementType {
  ADJUSTMENT
}

enum CustomerStoreStatus {
  ACTIVE
  INACTIVE
}

enum InvoiceDocumentType {
  STANDARD
}

enum InvoiceDocumentStatus {
  DRAFT
  ISSUED
  RECTIFIED
  VOIDED
}

enum InvoicePaymentStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  UNPAID
}

enum InvoiceVerifactuStatus {
  NOT_APPLICABLE
  PENDING
  SENT
  ACCEPTED
  ACCEPTED_WITH_ERRORS
  REJECTED
}

enum InvoiceOrigin {
  MANUAL
  SUBSCRIPTION
}

enum InvoiceDueDateStatus {
  PENDING
  PAID
  RETURNED
  UNPAID
}

enum CustomerPaymentSource {
  MANUAL
  SEPA_REMITTANCE
}

model Installation {
  id                     String             @id @default(uuid()) @db.Uuid
  singletonKey           Int                @default(1)
  status                 InstallationStatus @default(NOT_INITIALIZED)
  startedAt              DateTime?          @db.Timestamptz(3)
  completedAt            DateTime?          @db.Timestamptz(3)
  productVersion         String             @db.VarChar(32)
  failureCode            String?            @db.VarChar(100)
  companyId              String?            @unique @db.Uuid
  initialAdministratorId String?            @unique @db.Uuid
  createdAt              DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime           @updatedAt @db.Timestamptz(3)

  company              Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)
  initialAdministrator User?    @relation(fields: [initialAdministratorId], references: [id], onDelete: Restrict)

  @@unique([singletonKey])
  @@map("installations")
}

model Company {
  id        String   @id @default(uuid()) @db.Uuid
  legalName String   @db.VarChar(200)
  taxId     String   @unique @db.VarChar(32)
  email     String?  @db.VarChar(254)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  installation Installation?

  @@map("companies")
}

model Customer {
  id                   String                   @id @default(uuid()) @db.Uuid
  code                 String                   @unique @db.VarChar(20)
  type                 CustomerType
  status               CustomerStatus           @default(ACTIVE)
  legalName            String                   @db.VarChar(200)
  tradeName            String?                  @db.VarChar(160)
  taxId                String                   @db.VarChar(32)
  normalizedTaxId      String                   @unique @db.VarChar(64)
  fiscalTreatment      CustomerFiscalTreatment
  email                String?                  @db.VarChar(254)
  phone                String?                  @db.VarChar(40)
  fiscalAddressLine    String                   @db.VarChar(240)
  fiscalPostalCode     String                   @db.VarChar(20)
  fiscalCity           String                   @db.VarChar(120)
  fiscalProvince       String?                  @db.VarChar(120)
  fiscalCountry        String                   @db.VarChar(2)
  defaultPaymentMethod CustomerPaymentMethod    @default(BANK_TRANSFER)
  paymentTermsType     CustomerPaymentTermsType @default(IMMEDIATE)
  paymentDays          Int?
  paymentFixedDay      Int?
  creditLimit          Decimal?                 @db.Decimal(12, 2)
  bankIban             String?                  @db.VarChar(34)
  notes                String?                  @db.VarChar(1000)
  createdById          String                   @db.Uuid
  updatedById          String?                  @db.Uuid
  createdAt            DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime                 @updatedAt @db.Timestamptz(3)

  createdBy    User                  @relation("CustomersCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy    User?                 @relation("CustomersUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  addresses    CustomerAddress[]
  stores       CustomerStore[]
  sepaMandates CustomerSepaMandate[]
  invoices     Invoice[]

  @@index([status, legalName, id])
  @@index([createdAt, id])
  @@index([createdById, createdAt])
  @@map("customers")
}

model CustomerSepaMandate {
  id                  String                    @id @default(uuid()) @db.Uuid
  customerId          String                    @db.Uuid
  reference           String                    @db.VarChar(80)
  referenceNormalized String                    @unique @db.VarChar(80)
  status              CustomerSepaMandateStatus @default(ACTIVE)
  signedAt            DateTime                  @db.Date
  revokedAt           DateTime?                 @db.Timestamptz(3)
  createdById         String                    @db.Uuid
  revokedById         String?                   @db.Uuid
  createdAt           DateTime                  @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime                  @updatedAt @db.Timestamptz(3)

  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy User     @relation("CustomerSepaMandatesCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  revokedBy User?    @relation("CustomerSepaMandatesRevokedBy", fields: [revokedById], references: [id], onDelete: Restrict)

  @@index([customerId, status])
  @@index([createdById, createdAt])
  @@map("customer_sepa_mandates")
}

model CustomerAddress {
  id          String                @id @default(uuid()) @db.Uuid
  customerId  String                @db.Uuid
  type        CustomerAddressType
  status      CustomerAddressStatus @default(ACTIVE)
  label       String                @db.VarChar(120)
  isPrimary   Boolean               @default(false)
  addressLine String                @db.VarChar(240)
  postalCode  String                @db.VarChar(20)
  city        String                @db.VarChar(120)
  province    String?               @db.VarChar(120)
  country     String                @db.VarChar(2)
  contactName String?               @db.VarChar(160)
  phone       String?               @db.VarChar(40)
  email       String?               @db.VarChar(254)
  notes       String?               @db.VarChar(1000)
  createdById String                @db.Uuid
  updatedById String?               @db.Uuid
  createdAt   DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime              @updatedAt @db.Timestamptz(3)

  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy User     @relation("CustomerAddressesCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy User?    @relation("CustomerAddressesUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([customerId, type, status, isPrimary])
  @@index([customerId, status, label, id])
  @@index([createdById, createdAt])
  @@map("customer_addresses")
}

model CustomerStore {
  id              String              @id @default(uuid()) @db.Uuid
  customerId      String              @db.Uuid
  code            String              @unique @db.VarChar(20)
  name            String              @db.VarChar(160)
  status          CustomerStoreStatus @default(ACTIVE)
  isPrimary       Boolean             @default(false)
  addressLine     String              @db.VarChar(240)
  postalCode      String              @db.VarChar(20)
  city            String              @db.VarChar(120)
  province        String?             @db.VarChar(120)
  country         String              @db.VarChar(2)
  email           String?             @db.VarChar(254)
  phone           String?             @db.VarChar(40)
  whatsapp        String?             @db.VarChar(40)
  contactName     String?             @db.VarChar(160)
  contactRole     String?             @db.VarChar(120)
  contactPhone    String?             @db.VarChar(40)
  contactMobile   String?             @db.VarChar(40)
  contactWhatsapp String?             @db.VarChar(40)
  contactEmail    String?             @db.VarChar(254)
  notes           String?             @db.VarChar(1000)
  createdById     String              @db.Uuid
  updatedById     String?             @db.Uuid
  createdAt       DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime            @updatedAt @db.Timestamptz(3)

  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy User     @relation("CustomerStoresCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy User?    @relation("CustomerStoresUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([customerId, status, name, id])
  @@index([customerId, isPrimary])
  @@index([createdById, createdAt])
  @@map("customer_stores")
}

model User {
  id                 String     @id @default(uuid()) @db.Uuid
  displayName        String     @db.VarChar(160)
  userName           String     @unique @db.VarChar(80)
  normalizedUserName String     @unique @db.VarChar(80)
  passwordHash       String     @db.VarChar(500)
  status             UserStatus @default(ACTIVE)
  roleId             String     @db.Uuid
  failedLoginCount   Int        @default(0)
  lockedUntil        DateTime?  @db.Timestamptz(3)
  lastLoginAt        DateTime?  @db.Timestamptz(3)
  passwordChangedAt  DateTime   @default(now()) @db.Timestamptz(3)
  securityVersion    Int        @default(1)
  createdAt          DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime   @updatedAt @db.Timestamptz(3)

  role                          Role                       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  sessions                      Session[]
  requestedBackups              BackupOperation[]
  requestedRestores             RestoreOperation[]
  enabledMaintenances           PlatformMaintenanceState[] @relation("MaintenanceEnabledBy")
  disabledMaintenances          PlatformMaintenanceState[] @relation("MaintenanceDisabledBy")
  createdCustomers              Customer[]                 @relation("CustomersCreatedBy")
  updatedCustomers              Customer[]                 @relation("CustomersUpdatedBy")
  createdCustomerAddresses      CustomerAddress[]          @relation("CustomerAddressesCreatedBy")
  updatedCustomerAddresses      CustomerAddress[]          @relation("CustomerAddressesUpdatedBy")
  createdCustomerSepaMandates   CustomerSepaMandate[]      @relation("CustomerSepaMandatesCreatedBy")
  revokedCustomerSepaMandates   CustomerSepaMandate[]      @relation("CustomerSepaMandatesRevokedBy")
  createdCustomerStores         CustomerStore[]            @relation("CustomerStoresCreatedBy")
  updatedCustomerStores         CustomerStore[]            @relation("CustomerStoresUpdatedBy")
  createdCatalogItems           CatalogItem[]              @relation("CatalogItemsCreatedBy")
  updatedCatalogItems           CatalogItem[]              @relation("CatalogItemsUpdatedBy")
  createdCatalogStockMovements  CatalogStockMovement[]     @relation("CatalogStockMovementsCreatedBy")
  createdInvoices               Invoice[]                  @relation("InvoicesCreatedBy")
  updatedInvoices               Invoice[]                  @relation("InvoicesUpdatedBy")
  issuedInvoices                Invoice[]                  @relation("InvoicesIssuedBy")
  createdCustomerPayments       CustomerPayment[]          @relation("CustomerPaymentsCreatedBy")
  createdCustomerPaymentReturns CustomerPaymentReturn[]    @relation("CustomerPaymentReturnsCreatedBy")
  initialInstallation           Installation?

  @@map("users")
}

model CatalogItem {
  id           String            @id @default(uuid()) @db.Uuid
  code         String            @unique @db.VarChar(20)
  categoryId   String?           @db.Uuid
  kind         CatalogItemKind
  status       CatalogItemStatus @default(ACTIVE)
  name         String            @unique @db.VarChar(200)
  description  String?           @db.VarChar(1000)
  unitName     String            @default("Unidades") @db.VarChar(40)
  salePrice    Decimal           @db.Decimal(12, 2)
  costPrice    Decimal           @default(0) @db.Decimal(12, 2)
  taxRateId    String            @db.Uuid
  taxRate      Decimal           @default(21) @db.Decimal(5, 2)
  stockTracked Boolean           @default(false)
  stockCurrent Decimal           @default(0) @db.Decimal(12, 3)
  stockMinimum Decimal           @default(0) @db.Decimal(12, 3)
  createdById  String            @db.Uuid
  updatedById  String?           @db.Uuid
  createdAt    DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime          @updatedAt @db.Timestamptz(3)

  category          CatalogCategory?       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  taxRateDefinition CatalogTaxRate         @relation(fields: [taxRateId], references: [id], onDelete: Restrict)
  createdBy         User                   @relation("CatalogItemsCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy         User?                  @relation("CatalogItemsUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  stockMovements    CatalogStockMovement[]
  invoiceLines      InvoiceLine[]

  @@index([status, name, id])
  @@index([kind, status, name, id])
  @@index([categoryId, status, name, id])
  @@index([taxRateId])
  @@index([createdById, createdAt])
  @@map("catalog_items")
}

model CatalogStockMovement {
  id            String                   @id @default(uuid()) @db.Uuid
  itemId        String                   @db.Uuid
  type          CatalogStockMovementType @default(ADJUSTMENT)
  quantity      Decimal                  @db.Decimal(12, 3)
  previousStock Decimal                  @db.Decimal(12, 3)
  newStock      Decimal                  @db.Decimal(12, 3)
  reason        String                   @db.VarChar(500)
  createdById   String                   @db.Uuid
  createdAt     DateTime                 @default(now()) @db.Timestamptz(3)

  item      CatalogItem @relation(fields: [itemId], references: [id], onDelete: Restrict)
  createdBy User        @relation("CatalogStockMovementsCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([itemId, createdAt, id])
  @@index([createdById, createdAt])
  @@map("catalog_stock_movements")
}

model CatalogCategory {
  id          String                @id @default(uuid()) @db.Uuid
  code        String                @unique @db.VarChar(20)
  name        String                @unique @db.VarChar(120)
  description String?               @db.VarChar(500)
  status      CatalogCategoryStatus @default(ACTIVE)
  createdAt   DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime              @updatedAt @db.Timestamptz(3)

  items CatalogItem[]

  @@index([status, name, id])
  @@map("catalog_categories")
}

model CatalogTaxRate {
  id        String               @id @default(uuid()) @db.Uuid
  code      String               @unique @db.VarChar(40)
  name      String               @db.VarChar(120)
  rate      Decimal              @db.Decimal(5, 2)
  status    CatalogTaxRateStatus @default(ACTIVE)
  isDefault Boolean              @default(false)
  createdAt DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt DateTime             @updatedAt @db.Timestamptz(3)

  items        CatalogItem[]
  invoiceLines InvoiceLine[]

  @@index([status, name, id])
  @@map("catalog_tax_rates")
}

model BillingConfiguration {
  id                 String   @id @default(uuid()) @db.Uuid
  singletonKey       Int      @default(1)
  invoiceLegalFooter String   @default("") @db.Text
  invoiceAccentColor String   @default("#0f766e") @db.VarChar(7)
  createdAt          DateTime @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime @updatedAt @db.Timestamptz(3)

  @@unique([singletonKey])
  @@map("billing_configurations")
}

model InvoiceNumberSequence {
  id         String   @id @default(uuid()) @db.Uuid
  series     String   @db.VarChar(8)
  year       Int
  nextNumber Int      @default(1)
  updatedAt  DateTime @updatedAt @db.Timestamptz(3)

  @@unique([series, year])
  @@map("invoice_number_sequences")
}

model Invoice {
  id                              String                  @id @default(uuid()) @db.Uuid
  documentType                    InvoiceDocumentType     @default(STANDARD)
  origin                          InvoiceOrigin           @default(MANUAL)
  status                          InvoiceDocumentStatus   @default(DRAFT)
  paymentStatus                   InvoicePaymentStatus    @default(PENDING)
  verifactuStatus                 InvoiceVerifactuStatus  @default(NOT_APPLICABLE)
  series                          String                  @default("F") @db.VarChar(8)
  year                            Int
  numberSequence                  Int?
  number                          String?                 @unique @db.VarChar(20)
  customerId                      String                  @db.Uuid
  customerCodeSnapshot            String                  @db.VarChar(20)
  customerLegalNameSnapshot       String                  @db.VarChar(200)
  customerTaxIdSnapshot           String                  @db.VarChar(32)
  customerFiscalTreatmentSnapshot CustomerFiscalTreatment
  customerFiscalAddressSnapshot   Json
  issueDate                       DateTime                @db.Date
  operationDate                   DateTime                @db.Date
  issuedAt                        DateTime?               @db.Timestamptz(3)
  subtotal                        Decimal                 @default(0) @db.Decimal(12, 2)
  discountTotal                   Decimal                 @default(0) @db.Decimal(12, 2)
  taxableBase                     Decimal                 @default(0) @db.Decimal(12, 2)
  taxAmount                       Decimal                 @default(0) @db.Decimal(12, 2)
  total                           Decimal                 @default(0) @db.Decimal(12, 2)
  notes                           String?                 @db.VarChar(1000)
  createdById                     String                  @db.Uuid
  updatedById                     String?                 @db.Uuid
  issuedById                      String?                 @db.Uuid
  createdAt                       DateTime                @default(now()) @db.Timestamptz(3)
  updatedAt                       DateTime                @updatedAt @db.Timestamptz(3)

  customer        Customer                @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy       User                    @relation("InvoicesCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy       User?                   @relation("InvoicesUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  issuedBy        User?                   @relation("InvoicesIssuedBy", fields: [issuedById], references: [id], onDelete: Restrict)
  lines           InvoiceLine[]
  taxSummaries    InvoiceTaxSummary[]
  dueDates        InvoiceDueDate[]
  payments        CustomerPayment[]
  paymentReturns  CustomerPaymentReturn[]
  verifactuRecord InvoiceVerifactuRecord?

  @@unique([series, year, numberSequence])
  @@index([status, issueDate, id])
  @@index([customerId, issueDate, id])
  @@index([paymentStatus, issueDate, id])
  @@index([verifactuStatus, issueDate, id])
  @@index([createdById, createdAt])
  @@map("invoices")
}

model InvoiceLine {
  id                      String           @id @default(uuid()) @db.Uuid
  invoiceId               String           @db.Uuid
  position                Int
  catalogItemId           String?          @db.Uuid
  catalogItemCodeSnapshot String?          @db.VarChar(20)
  catalogItemKindSnapshot CatalogItemKind?
  description             String           @db.VarChar(500)
  quantity                Decimal          @db.Decimal(12, 3)
  unitPrice               Decimal          @db.Decimal(12, 2)
  discountPercent         Decimal          @default(0) @db.Decimal(5, 2)
  discountAmount          Decimal          @default(0) @db.Decimal(12, 2)
  taxRateId               String           @db.Uuid
  taxRateCodeSnapshot     String           @db.VarChar(40)
  taxRateNameSnapshot     String           @db.VarChar(120)
  taxRateSnapshot         Decimal          @db.Decimal(5, 2)
  lineSubtotal            Decimal          @db.Decimal(12, 2)
  lineDiscountTotal       Decimal          @db.Decimal(12, 2)
  lineTaxableBase         Decimal          @db.Decimal(12, 2)
  lineTaxAmount           Decimal          @db.Decimal(12, 2)
  lineTotal               Decimal          @db.Decimal(12, 2)
  createdAt               DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt               DateTime         @updatedAt @db.Timestamptz(3)

  invoice     Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  catalogItem CatalogItem?   @relation(fields: [catalogItemId], references: [id], onDelete: Restrict)
  taxRate     CatalogTaxRate @relation(fields: [taxRateId], references: [id], onDelete: Restrict)

  @@unique([invoiceId, position])
  @@index([catalogItemId])
  @@index([taxRateId])
  @@map("invoice_lines")
}

model InvoiceTaxSummary {
  id          String  @id @default(uuid()) @db.Uuid
  invoiceId   String  @db.Uuid
  taxRateCode String  @db.VarChar(40)
  taxRate     Decimal @db.Decimal(5, 2)
  taxableBase Decimal @db.Decimal(12, 2)
  taxAmount   Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@unique([invoiceId, taxRateCode, taxRate])
  @@map("invoice_tax_summaries")
}

model InvoiceDueDate {
  id            String                @id @default(uuid()) @db.Uuid
  invoiceId     String                @db.Uuid
  position      Int
  dueDate       DateTime              @db.Date
  amount        Decimal               @db.Decimal(12, 2)
  paymentMethod CustomerPaymentMethod
  status        InvoiceDueDateStatus  @default(PENDING)

  invoice        Invoice                 @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  payments       CustomerPayment[]
  paymentReturns CustomerPaymentReturn[]

  @@unique([invoiceId, position])
  @@index([status, dueDate, id])
  @@map("invoice_due_dates")
}

model CustomerPayment {
  id          String                @id @default(uuid()) @db.Uuid
  invoiceId   String                @db.Uuid
  dueDateId   String                @db.Uuid
  source      CustomerPaymentSource @default(MANUAL)
  paymentDate DateTime              @db.Date
  amount      Decimal               @db.Decimal(12, 2)
  reference   String?               @db.VarChar(120)
  notes       String?               @db.VarChar(500)
  createdById String                @db.Uuid
  createdAt   DateTime              @default(now()) @db.Timestamptz(3)

  invoice   Invoice                 @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  dueDate   InvoiceDueDate          @relation(fields: [dueDateId], references: [id], onDelete: Restrict)
  createdBy User                    @relation("CustomerPaymentsCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  returns   CustomerPaymentReturn[]

  @@index([invoiceId, paymentDate, id])
  @@index([dueDateId, paymentDate, id])
  @@index([createdById, createdAt])
  @@map("customer_payments")
}

model CustomerPaymentReturn {
  id          String   @id @default(uuid()) @db.Uuid
  paymentId   String   @db.Uuid
  invoiceId   String   @db.Uuid
  dueDateId   String   @db.Uuid
  returnDate  DateTime @db.Date
  amount      Decimal  @db.Decimal(12, 2)
  reasonCode  String?  @db.VarChar(80)
  notes       String?  @db.VarChar(500)
  createdById String   @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz(3)

  payment   CustomerPayment @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  invoice   Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  dueDate   InvoiceDueDate  @relation(fields: [dueDateId], references: [id], onDelete: Restrict)
  createdBy User            @relation("CustomerPaymentReturnsCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([paymentId, returnDate, id])
  @@index([invoiceId, returnDate, id])
  @@index([dueDateId, returnDate, id])
  @@index([createdById, createdAt])
  @@map("customer_payment_returns")
}

model InvoiceVerifactuRecord {
  id            String                 @id @default(uuid()) @db.Uuid
  invoiceId     String                 @unique @db.Uuid
  status        InvoiceVerifactuStatus @default(PENDING)
  lastErrorCode String?                @db.VarChar(120)
  createdAt     DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime               @updatedAt @db.Timestamptz(3)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@index([status, createdAt])
  @@map("invoice_verifactu_records")
}

model ReservedUserName {
  id                 String   @id @default(uuid()) @db.Uuid
  normalizedUserName String   @unique @db.VarChar(80)
  reservedByUserId   String?  @db.Uuid
  reason             String   @db.VarChar(80)
  createdAt          DateTime @default(now()) @db.Timestamptz(3)

  @@map("reserved_user_names")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(80)
  name        String   @db.VarChar(120)
  isProtected Boolean  @default(false)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(120)
  name      String   @db.VarChar(160)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuditEvent {
  id        String   @id @default(uuid()) @db.Uuid
  eventType String   @db.VarChar(120)
  actorType String   @db.VarChar(40)
  payload   Json
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([createdAt, id])
  @@index([eventType, createdAt])
  @@map("audit_events")
}

model Session {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  tokenHash       String    @unique @db.VarChar(128)
  startedAt       DateTime  @default(now()) @db.Timestamptz(3)
  lastActivityAt  DateTime  @default(now()) @db.Timestamptz(3)
  expiresAt       DateTime  @db.Timestamptz(3)
  revokedAt       DateTime? @db.Timestamptz(3)
  revokeReason    String?   @db.VarChar(120)
  ipAddress       String?   @db.VarChar(64)
  userAgent       String?   @db.VarChar(500)
  securityVersion Int

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("sessions")
}

model LoginAttempt {
  id                 String   @id @default(uuid()) @db.Uuid
  normalizedUserName String   @db.VarChar(80)
  succeeded          Boolean
  failureCode        String?  @db.VarChar(80)
  ipAddress          String?  @db.VarChar(64)
  userAgent          String?  @db.VarChar(500)
  createdAt          DateTime @default(now()) @db.Timestamptz(3)

  @@index([normalizedUserName, createdAt])
  @@index([ipAddress, createdAt])
  @@map("login_attempts")
}

model RateLimitBucket {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(200)
  windowStart DateTime @db.Timestamptz(3)
  count       Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  @@index([windowStart])
  @@map("rate_limit_buckets")
}

model IdempotencyRecord {
  id             String   @id @default(uuid()) @db.Uuid
  key            String   @unique @db.VarChar(160)
  requestHash    String   @db.VarChar(64)
  responseStatus Int
  responseBody   Json
  createdAt      DateTime @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @db.Timestamptz(3)

  @@index([createdAt])
  @@map("idempotency_records")
}

model BackupOperation {
  id             String                @id @default(uuid()) @db.Uuid
  status         BackupOperationStatus @default(REQUESTED)
  requestedById  String                @db.Uuid
  requestedAt    DateTime              @default(now()) @db.Timestamptz(3)
  startedAt      DateTime?             @db.Timestamptz(3)
  completedAt    DateTime?             @db.Timestamptz(3)
  productVersion String                @db.VarChar(32)
  storageKey     String?               @db.VarChar(500)
  sizeBytes      BigInt?
  sha256         String?               @db.Char(64)
  errorCode      String?               @db.VarChar(120)
  createdAt      DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime              @updatedAt @db.Timestamptz(3)

  requestedBy    User               @relation(fields: [requestedById], references: [id], onDelete: Restrict)
  restoreSources RestoreOperation[] @relation("RestoreSourceBackup")
  preRestoreUses RestoreOperation[] @relation("PreRestoreBackup")

  @@index([status, requestedAt])
  @@index([requestedAt, id])
  @@index([requestedById, requestedAt])
  @@map("backup_operations")
}

model RestoreOperation {
  id                          String                 @id @default(uuid()) @db.Uuid
  status                      RestoreOperationStatus @default(REQUESTED)
  backupOperationId           String                 @db.Uuid
  requestedById               String                 @db.Uuid
  reason                      String                 @db.VarChar(500)
  requestedAt                 DateTime               @default(now()) @db.Timestamptz(3)
  startedAt                   DateTime?              @db.Timestamptz(3)
  validatedAt                 DateTime?              @db.Timestamptz(3)
  completedAt                 DateTime?              @db.Timestamptz(3)
  preRestoreBackupOperationId String?                @db.Uuid
  errorCode                   String?                @db.VarChar(120)
  createdAt                   DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt                   DateTime               @updatedAt @db.Timestamptz(3)

  backupOperation           BackupOperation            @relation("RestoreSourceBackup", fields: [backupOperationId], references: [id], onDelete: Restrict)
  requestedBy               User                       @relation(fields: [requestedById], references: [id], onDelete: Restrict)
  preRestoreBackupOperation BackupOperation?           @relation("PreRestoreBackup", fields: [preRestoreBackupOperationId], references: [id], onDelete: Restrict)
  maintenanceStates         PlatformMaintenanceState[]

  @@index([status, requestedAt])
  @@index([requestedAt, id])
  @@index([backupOperationId, requestedAt])
  @@index([requestedById, requestedAt])
  @@map("restore_operations")
}

model PlatformMaintenanceState {
  id                 String                   @id @default(uuid()) @db.Uuid
  singletonKey       Int                      @default(1)
  enabled            Boolean                  @default(false)
  mode               PlatformMaintenanceMode?
  reason             String?                  @db.VarChar(500)
  restoreOperationId String?                  @db.Uuid
  enabledById        String?                  @db.Uuid
  disabledById       String?                  @db.Uuid
  enabledAt          DateTime?                @db.Timestamptz(3)
  disabledAt         DateTime?                @db.Timestamptz(3)
  createdAt          DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime                 @updatedAt @db.Timestamptz(3)

  restoreOperation RestoreOperation? @relation(fields: [restoreOperationId], references: [id], onDelete: Restrict)
  enabledBy        User?             @relation("MaintenanceEnabledBy", fields: [enabledById], references: [id], onDelete: Restrict)
  disabledBy       User?             @relation("MaintenanceDisabledBy", fields: [disabledById], references: [id], onDelete: Restrict)

  @@unique([singletonKey])
  @@index([enabled, mode])
  @@index([restoreOperationId])
  @@map("platform_maintenance_state")
}
