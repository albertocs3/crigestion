model InvoiceNumberSequence {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  series     String   @db.VarChar(8)
  year       Int
  nextNumber Int      @default(1)
  updatedAt  DateTime @updatedAt @db.Timestamptz(3)

  @@unique([series, year])
  @@map("invoice_number_sequences")
}

model Invoice {
  id                              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId                       String?                 @db.Uuid
  documentType                    InvoiceDocumentType     @default(STANDARD)
  origin                          InvoiceOrigin           @default(MANUAL)
  status                          InvoiceDocumentStatus   @default(DRAFT)
  paymentStatus                   InvoicePaymentStatus    @default(PENDING)
  verifactuStatus                 InvoiceVerifactuStatus  @default(NOT_APPLICABLE)
  series                          String                  @default("F") @db.VarChar(8)
  year                            Int
  numberSequence                  Int?
  number                          String?                 @unique @db.VarChar(20)
  customerId                      String                  @db.Uuid
  customerCodeSnapshot            String                  @db.VarChar(20)
  customerLegalNameSnapshot       String                  @db.VarChar(200)
  customerTaxIdSnapshot           String                  @db.VarChar(32)
  customerFiscalTreatmentSnapshot CustomerFiscalTreatment
  customerFiscalAddressSnapshot   Json
  issueDate                       DateTime                @db.Date
  operationDate                   DateTime                @db.Date
  issuedAt                        DateTime?               @db.Timestamptz(3)
  subtotal                        Decimal                 @default(0) @db.Decimal(12, 2)
  discountTotal                   Decimal                 @default(0) @db.Decimal(12, 2)
  taxableBase                     Decimal                 @default(0) @db.Decimal(12, 2)
  taxAmount                       Decimal                 @default(0) @db.Decimal(12, 2)
  total                           Decimal                 @default(0) @db.Decimal(12, 2)
  notes                           String?                 @db.VarChar(1000)
  rectificationReason             String?                 @db.VarChar(120)
  rectifiesInvoiceId              String?                 @unique @db.Uuid
  createdById                     String                  @db.Uuid
  updatedById                     String?                 @db.Uuid
  issuedById                      String?                 @db.Uuid
  createdAt                       DateTime                @default(now()) @db.Timestamptz(3)
  updatedAt                       DateTime                @updatedAt @db.Timestamptz(3)

  customer               Customer                    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  company                Company?                    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  rectifiesInvoice       Invoice?                    @relation("InvoiceRectifications", fields: [rectifiesInvoiceId], references: [id], onDelete: Restrict)
  rectificationInvoices  Invoice[]                   @relation("InvoiceRectifications")
  createdBy              User                        @relation("InvoicesCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy              User?                       @relation("InvoicesUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  issuedBy               User?                       @relation("InvoicesIssuedBy", fields: [issuedById], references: [id], onDelete: Restrict)
  lines                  InvoiceLine[]
  taxSummaries           InvoiceTaxSummary[]
  dueDates               InvoiceDueDate[]
  payments               CustomerPayment[]
  paymentReturns         CustomerPaymentReturn[]
  remittanceLines        CustomerRemittanceLine[]
  verifactuRecord        InvoiceVerifactuRecord?
  accountingEntry        AccountingJournalEntry?
  voidingAccountingEntry AccountingJournalEntry?     @relation("InvoiceVoidingEntry")
  verifactuFiscalRecords VerifactuFiscalRecord[]
  sourceCustomerCredit   CustomerCredit?             @relation("CustomerCreditSource")
  creditApplications     CustomerCreditApplication[] @relation("CreditApplicationTargetInvoice")

  @@unique([series, year, numberSequence])
  @@unique([id, companyId])
  @@index([status, issueDate, id])
  @@index([customerId, issueDate, id])
  @@index([paymentStatus, issueDate, id])
  @@index([verifactuStatus, issueDate, id])
  @@index([createdById, createdAt])
  @@index([companyId, issueDate, id])
  @@map("invoices")
}

model InvoiceLine {
  id                      String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId               String           @db.Uuid
  position                Int
  catalogItemId           String?          @db.Uuid
  catalogItemCodeSnapshot String?          @db.VarChar(20)
  catalogItemKindSnapshot CatalogItemKind?
  description             String           @db.VarChar(500)
  quantity                Decimal          @db.Decimal(12, 3)
  unitPrice               Decimal          @db.Decimal(12, 2)
  discountPercent         Decimal          @default(0) @db.Decimal(5, 2)
  discountAmount          Decimal          @default(0) @db.Decimal(12, 2)
  taxRateId               String           @db.Uuid
  taxRateCodeSnapshot     String           @db.VarChar(40)
  taxRateNameSnapshot     String           @db.VarChar(120)
  taxRateSnapshot         Decimal          @db.Decimal(5, 2)
  lineSubtotal            Decimal          @db.Decimal(12, 2)
  lineDiscountTotal       Decimal          @db.Decimal(12, 2)
  lineTaxableBase         Decimal          @db.Decimal(12, 2)
  lineTaxAmount           Decimal          @db.Decimal(12, 2)
  lineTotal               Decimal          @db.Decimal(12, 2)
  createdAt               DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt               DateTime         @updatedAt @db.Timestamptz(3)

  invoice     Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  catalogItem CatalogItem?   @relation(fields: [catalogItemId], references: [id], onDelete: Restrict)
  taxRate     CatalogTaxRate @relation(fields: [taxRateId], references: [id], onDelete: Restrict)

  @@unique([invoiceId, position])
  @@index([catalogItemId])
  @@index([taxRateId])
  @@map("invoice_lines")
}

model InvoiceTaxSummary {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId   String  @db.Uuid
  taxRateCode String  @db.VarChar(40)
  taxRate     Decimal @db.Decimal(5, 2)
