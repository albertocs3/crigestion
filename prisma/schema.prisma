  disabledMaintenances          PlatformMaintenanceState[]           @relation("MaintenanceDisabledBy")
  createdCustomers              Customer[]                           @relation("CustomersCreatedBy")
  updatedCustomers              Customer[]                           @relation("CustomersUpdatedBy")
  createdSuppliers              Supplier[]                           @relation("SuppliersCreatedBy")
  updatedSuppliers              Supplier[]                           @relation("SuppliersUpdatedBy")
  createdPurchaseInvoices       PurchaseInvoice[]                    @relation("PurchaseInvoicesCreatedBy")
  updatedPurchaseInvoices       PurchaseInvoice[]                    @relation("PurchaseInvoicesUpdatedBy")
  registeredPurchaseInvoices    PurchaseInvoice[]                    @relation("PurchaseInvoicesRegisteredBy")
  createdSupplierPayments       SupplierPayment[]                    @relation("SupplierPaymentsCreatedBy")
  createdCustomerAddresses      CustomerAddress[]                    @relation("CustomerAddressesCreatedBy")
  updatedCustomerAddresses      CustomerAddress[]                    @relation("CustomerAddressesUpdatedBy")
  createdCustomerSepaMandates   CustomerSepaMandate[]                @relation("CustomerSepaMandatesCreatedBy")
  revokedCustomerSepaMandates   CustomerSepaMandate[]                @relation("CustomerSepaMandatesRevokedBy")
  createdCustomerStores         CustomerStore[]                      @relation("CustomerStoresCreatedBy")
  updatedCustomerStores         CustomerStore[]                      @relation("CustomerStoresUpdatedBy")
  createdCatalogItems           CatalogItem[]                        @relation("CatalogItemsCreatedBy")
  updatedCatalogItems           CatalogItem[]                        @relation("CatalogItemsUpdatedBy")
  createdCatalogStockMovements  CatalogStockMovement[]               @relation("CatalogStockMovementsCreatedBy")
  createdInvoices               Invoice[]                            @relation("InvoicesCreatedBy")
  updatedInvoices               Invoice[]                            @relation("InvoicesUpdatedBy")
  issuedInvoices                Invoice[]                            @relation("InvoicesIssuedBy")
  createdCustomerPayments       CustomerPayment[]                    @relation("CustomerPaymentsCreatedBy")
  createdCustomerPaymentReturns CustomerPaymentReturn[]              @relation("CustomerPaymentReturnsCreatedBy")
  createdCustomerCredits        CustomerCredit[]                     @relation("CustomerCreditsCreatedBy")
  createdCreditApplications     CustomerCreditApplication[]          @relation("CustomerCreditApplicationsCreatedBy")
  requestedCreditRefunds        CustomerCreditRefund[]               @relation("CustomerCreditRefundsRequestedBy")
  approvedCreditRefunds         CustomerCreditRefund[]               @relation("CustomerCreditRefundsApprovedBy")
  postedCreditRefunds           CustomerCreditRefund[]               @relation("CustomerCreditRefundsPostedBy")
  cancelledCreditRefunds        CustomerCreditRefund[]               @relation("CustomerCreditRefundsCancelledBy")
  createdCustomerRemittances    CustomerRemittance[]                 @relation("CustomerRemittancesCreatedBy")
  updatedCustomerRemittances    CustomerRemittance[]                 @relation("CustomerRemittancesUpdatedBy")
  createdAccountingAccounts     AccountingAccount[]                  @relation("AccountingAccountsCreatedBy")
  createdAccountingFiscalYears  AccountingFiscalYear[]               @relation("AccountingFiscalYearsCreatedBy")
  closedAccountingFiscalYears   AccountingFiscalYear[]               @relation("AccountingFiscalYearsClosedBy")
  createdAccountingEntries      AccountingJournalEntry[]             @relation("AccountingEntriesCreatedBy")
  updatedAccountingEntries      AccountingJournalEntry[]             @relation("AccountingEntriesUpdatedBy")
  createdBankAccounts           BankAccount[]                        @relation("BankAccountsCreatedBy")
  createdBankMovements          BankMovement[]                       @relation("BankMovementsCreatedBy")
  createdBankReconciliations    BankReconciliation[]                 @relation("BankReconciliationsCreatedBy")
  undoneBankReconciliations     BankReconciliation[]                 @relation("BankReconciliationsUndoneBy")
  importedBankStatements        BankStatement[]                      @relation("BankStatementsImportedBy")
  verifactuCredentialTests      VerifactuMtlsCredentialTestAttempt[]
  initialInstallation           Installation?

  @@map("users")
}

model CatalogItem {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String            @unique @db.VarChar(20)
  categoryId          String?           @db.Uuid
  kind                CatalogItemKind
  status              CatalogItemStatus @default(ACTIVE)
  name                String            @unique @db.VarChar(200)
  description         String?           @db.VarChar(1000)
  unitName            String            @default("Unidades") @db.VarChar(40)
  salePrice           Decimal           @db.Decimal(12, 2)
  costPrice           Decimal           @default(0) @db.Decimal(12, 2)
  taxRateId           String            @db.Uuid
  taxRate             Decimal           @default(21) @db.Decimal(5, 2)
  purchaseAccountCode String?           @db.VarChar(9)
  stockTracked        Boolean           @default(false)
  stockCurrent        Decimal           @default(0) @db.Decimal(12, 3)
  stockMinimum        Decimal           @default(0) @db.Decimal(12, 3)
  createdById         String            @db.Uuid
  updatedById         String?           @db.Uuid
  createdAt           DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime          @updatedAt @db.Timestamptz(3)

  category             CatalogCategory?       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  taxRateDefinition    CatalogTaxRate         @relation(fields: [taxRateId], references: [id], onDelete: Restrict)
  createdBy            User                   @relation("CatalogItemsCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy            User?                  @relation("CatalogItemsUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  stockMovements       CatalogStockMovement[]
  invoiceLines         InvoiceLine[]
  purchaseInvoiceLines PurchaseInvoiceLine[]

  @@index([status, name, id])
  @@index([kind, status, name, id])
  @@index([categoryId, status, name, id])
  @@index([taxRateId])
  @@index([createdById, createdAt])
  @@map("catalog_items")
}

model CatalogStockMovement {
  id                    String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemId                String                   @db.Uuid
  purchaseInvoiceLineId String?                  @unique @db.Uuid
  reversesMovementId    String?                  @unique @db.Uuid
  type                  CatalogStockMovementType @default(ADJUSTMENT)
  quantity              Decimal                  @db.Decimal(12, 3)
  previousStock         Decimal                  @db.Decimal(12, 3)
  newStock              Decimal                  @db.Decimal(12, 3)
  reason                String                   @db.VarChar(500)
  createdById           String                   @db.Uuid
  createdAt             DateTime                 @default(now()) @db.Timestamptz(3)

  item                CatalogItem          @relation(fields: [itemId], references: [id], onDelete: Restrict)
  purchaseInvoiceLine PurchaseInvoiceLine? @relation(fields: [purchaseInvoiceLineId], references: [id], onDelete: Restrict)
  reversesMovement    CatalogStockMovement?  @relation("CatalogStockMovementReversals", fields: [reversesMovementId], references: [id], onDelete: Restrict)
  reversedByMovement  CatalogStockMovement?  @relation("CatalogStockMovementReversals")
  createdBy           User                 @relation("CatalogStockMovementsCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([itemId, createdAt, id])
  @@index([createdById, createdAt])
  @@map("catalog_stock_movements")
}

model CatalogCategory {
