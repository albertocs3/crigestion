  generatedAt             DateTime            @db.Timestamptz(3)
  contractVersion         String              @db.VarChar(32)
  schemaVersion           String              @db.VarChar(32)
  canonicalizationVersion String              @db.VarChar(32)
  hashAlgorithm           String              @default("SHA-256") @db.VarChar(20)
  previousHash            String?             @db.Char(64)
  recordHash              String              @db.Char(64)
  fiscalSnapshot          Json
  payloadCiphertext       Bytes
  encryptionKeyId         String              @db.VarChar(120)
  payloadSha256           String              @db.Char(64)
  qrUrl                   String?             @db.Text
  preparationKey          String              @unique @db.VarChar(160)
  createdAt               DateTime            @default(now()) @db.Timestamptz(3)

  company           Company                      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  sifInstallation   VerifactuSifInstallation     @relation("VerifactuInstallationRecords", fields: [sifInstallationId, companyId], references: [id, companyId], onDelete: Restrict, map: "verifactu_fiscal_records_installation_company_fkey")
  installationHeads VerifactuSifInstallation[]   @relation("VerifactuInstallationHead")
  invoice           Invoice                      @relation(fields: [invoiceId, companyId], references: [id, companyId], onDelete: Restrict, map: "verifactu_fiscal_records_invoice_company_fkey")
  previousRecord    VerifactuFiscalRecord?       @relation("VerifactuRecordChain", fields: [previousRecordId, sifInstallationId], references: [id, sifInstallationId], onDelete: Restrict, map: "verifactu_fiscal_records_previous_chain_fkey")
  nextRecord        VerifactuFiscalRecord?       @relation("VerifactuRecordChain")
  cancelledRecord   VerifactuFiscalRecord?       @relation("VerifactuRecordCancellation", fields: [cancelledRecordId, sifInstallationId, invoiceId], references: [id, sifInstallationId, invoiceId], onDelete: Restrict, map: "verifactu_fiscal_records_cancelled_target_fkey")
  cancellation      VerifactuFiscalRecord?       @relation("VerifactuRecordCancellation")
  correctedRecord   VerifactuFiscalRecord?       @relation("VerifactuRecordCorrection", fields: [correctedRecordId, sifInstallationId, invoiceId], references: [id, sifInstallationId, invoiceId], onDelete: Restrict, map: "verifactu_fiscal_records_corrected_target_fkey")
  correction        VerifactuFiscalRecord?       @relation("VerifactuRecordCorrection")
  attempts          VerifactuSubmissionAttempt[]
  outboxMessages    VerifactuOutboxMessage[]

  @@unique([sifInstallationId, chainPosition])
  @@unique([sifInstallationId, recordHash])
  @@unique([previousRecordId, sifInstallationId])
  @@unique([cancelledRecordId, sifInstallationId, invoiceId], map: "verifactu_fiscal_records_cancelledRecordId_sifInstallationId_in")
  @@unique([correctedRecordId, sifInstallationId, invoiceId], map: "verifactu_fiscal_records_correctedRecordId_sifInstallationId_in")
  @@unique([id, sifInstallationId])
  @@unique([id, sifInstallationId, invoiceId])
  @@index([companyId, invoiceIssueDate, id])
  @@index([invoiceId, createdAt, id])
  @@map("verifactu_fiscal_records")
}

model VerifactuSubmissionAttempt {
  id                   String                  @id @default(uuid()) @db.Uuid
  fiscalRecordId       String                  @db.Uuid
  attemptNumber        Int
  kind                 VerifactuAttemptKind
  idempotencyKey       String                  @unique @db.VarChar(160)
  startedAt            DateTime                @db.Timestamptz(3)
  completedAt          DateTime                @db.Timestamptz(3)
  outcome              VerifactuAttemptOutcome
  requestCiphertext    Bytes?
  responseCiphertext   Bytes?
  encryptionKeyId      String?                 @db.VarChar(120)
  requestSha256        String                  @db.Char(64)
  responseSha256       String?                 @db.Char(64)
  externalSubmissionId String?                 @db.VarChar(160)
  aeatCsv              String?                 @db.VarChar(160)
  aeatCodes            Json?
  stableErrorCode      String?                 @db.VarChar(120)
  credentialVersionId  String?                 @db.Uuid
  createdAt            DateTime                @default(now()) @db.Timestamptz(3)

  fiscalRecord      VerifactuFiscalRecord           @relation(fields: [fiscalRecordId], references: [id], onDelete: Restrict)
  credentialVersion VerifactuMtlsCredentialVersion? @relation(fields: [credentialVersionId], references: [id], onDelete: Restrict)

  @@unique([fiscalRecordId, attemptNumber])
  @@index([fiscalRecordId, createdAt, id])
  @@index([outcome, createdAt, id])
  @@index([credentialVersionId, createdAt, id], map: "verifactu_submission_attempts_credential_version_created_idx")
  @@map("verifactu_submission_attempts")
}

model VerifactuOutboxMessage {
  id             String                @id @default(uuid()) @db.Uuid
  fiscalRecordId String                @db.Uuid
  operation      VerifactuAttemptKind
  idempotencyKey String                @unique @db.VarChar(160)
  bodySha256     String                @db.Char(64)
  status         VerifactuOutboxStatus @default(PENDING)
  attemptCount   Int                   @default(0)
  maxAttempts    Int                   @default(20)
  nextAttemptAt  DateTime              @default(now()) @db.Timestamptz(3)
  leaseOwner     String?               @db.VarChar(160)
  leaseToken     String?               @db.Uuid
  leaseUntil     DateTime?             @db.Timestamptz(3)
  lastErrorCode  String?               @db.VarChar(120)
  createdAt      DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime              @updatedAt @db.Timestamptz(3)
  processedAt    DateTime?             @db.Timestamptz(3)

  fiscalRecord VerifactuFiscalRecord @relation(fields: [fiscalRecordId], references: [id], onDelete: Restrict)

  @@unique([fiscalRecordId, operation])
  @@index([status, nextAttemptAt, createdAt, id])
  @@index([leaseUntil, status])
  @@map("verifactu_outbox_messages")
}

model VerifactuWorkerRun {
  id              String                   @id @default(uuid()) @db.Uuid
  companyId       String                   @db.Uuid
  workerId        String                   @unique @db.VarChar(160)
  environment     VerifactuEnvironment
  status          VerifactuWorkerStatus
  startedAt       DateTime                 @db.Timestamptz(3)
  heartbeatAt     DateTime                 @db.Timestamptz(3)
  lastPollAt      DateTime?                @db.Timestamptz(3)
  lastProcessedAt DateTime?                @db.Timestamptz(3)
  stoppedAt       DateTime?                @db.Timestamptz(3)
  lastOutcome     VerifactuAttemptOutcome?
  lastErrorCode   String?                  @db.VarChar(120)
  processedCount  Int                      @default(0)
  idleCount       Int                      @default(0)
  errorCount      Int                      @default(0)
  leaseLostCount  Int                      @default(0)
  createdAt       DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime                 @updatedAt @db.Timestamptz(3)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId, environment, status, heartbeatAt], map: "verifactu_worker_runs_companyId_environment_status_heartbeatAt_")
  @@index([heartbeatAt])
  @@map("verifactu_worker_runs")
}

model ReservedUserName {
  id                 String   @id @default(uuid()) @db.Uuid
  normalizedUserName String   @unique @db.VarChar(80)
  reservedByUserId   String?  @db.Uuid
  reason             String   @db.VarChar(80)
  createdAt          DateTime @default(now()) @db.Timestamptz(3)

  @@map("reserved_user_names")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(80)
  name        String   @db.VarChar(120)
  isProtected Boolean  @default(false)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(120)
  name      String   @db.VarChar(160)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuditEvent {
  id        String   @id @default(uuid()) @db.Uuid
  eventType String   @db.VarChar(120)
  actorType String   @db.VarChar(40)
  payload   Json
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([createdAt, id])
  @@index([eventType, createdAt])
  @@map("audit_events")
}

model Session {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  tokenHash       String    @unique @db.VarChar(128)
  startedAt       DateTime  @default(now()) @db.Timestamptz(3)
  lastActivityAt  DateTime  @default(now()) @db.Timestamptz(3)
  expiresAt       DateTime  @db.Timestamptz(3)
  revokedAt       DateTime? @db.Timestamptz(3)
  revokeReason    String?   @db.VarChar(120)
  ipAddress       String?   @db.VarChar(64)
  userAgent       String?   @db.VarChar(500)
  securityVersion Int

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("sessions")
}

model LoginAttempt {
  id                 String   @id @default(uuid()) @db.Uuid
  normalizedUserName String   @db.VarChar(80)
  succeeded          Boolean
  failureCode        String?  @db.VarChar(80)
  ipAddress          String?  @db.VarChar(64)
  userAgent          String?  @db.VarChar(500)
  createdAt          DateTime @default(now()) @db.Timestamptz(3)

  @@index([normalizedUserName, createdAt])
  @@index([ipAddress, createdAt])
  @@map("login_attempts")
}

model RateLimitBucket {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(200)
  windowStart DateTime @db.Timestamptz(3)
  count       Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  @@index([windowStart])
  @@map("rate_limit_buckets")
}

model IdempotencyRecord {
  id             String   @id @default(uuid()) @db.Uuid
  key            String   @unique @db.VarChar(160)
  requestHash    String   @db.VarChar(64)
  responseStatus Int
  responseBody   Json
  createdAt      DateTime @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @db.Timestamptz(3)

  @@index([createdAt])
  @@map("idempotency_records")
}

model BackupOperation {
  id             String                @id @default(uuid()) @db.Uuid
  status         BackupOperationStatus @default(REQUESTED)
  requestedById  String                @db.Uuid
  requestedAt    DateTime              @default(now()) @db.Timestamptz(3)
  startedAt      DateTime?             @db.Timestamptz(3)
  completedAt    DateTime?             @db.Timestamptz(3)
  productVersion String                @db.VarChar(32)
  storageKey     String?               @db.VarChar(500)
  sizeBytes      BigInt?
  sha256         String?               @db.Char(64)
  errorCode      String?               @db.VarChar(120)
  createdAt      DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime              @updatedAt @db.Timestamptz(3)

  requestedBy    User               @relation(fields: [requestedById], references: [id], onDelete: Restrict)
  restoreSources RestoreOperation[] @relation("RestoreSourceBackup")
  preRestoreUses RestoreOperation[] @relation("PreRestoreBackup")

  @@index([status, requestedAt])
  @@index([requestedAt, id])
  @@index([requestedById, requestedAt])
  @@map("backup_operations")
}

model RestoreOperation {
  id                          String                 @id @default(uuid()) @db.Uuid
  status                      RestoreOperationStatus @default(REQUESTED)
  backupOperationId           String                 @db.Uuid
  requestedById               String                 @db.Uuid
  reason                      String                 @db.VarChar(500)
  requestedAt                 DateTime               @default(now()) @db.Timestamptz(3)
  startedAt                   DateTime?              @db.Timestamptz(3)
  validatedAt                 DateTime?              @db.Timestamptz(3)
  completedAt                 DateTime?              @db.Timestamptz(3)
  preRestoreBackupOperationId String?                @db.Uuid
  errorCode                   String?                @db.VarChar(120)
  createdAt                   DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt                   DateTime               @updatedAt @db.Timestamptz(3)

  backupOperation           BackupOperation            @relation("RestoreSourceBackup", fields: [backupOperationId], references: [id], onDelete: Restrict)
  requestedBy               User                       @relation(fields: [requestedById], references: [id], onDelete: Restrict)
  preRestoreBackupOperation BackupOperation?           @relation("PreRestoreBackup", fields: [preRestoreBackupOperationId], references: [id], onDelete: Restrict)
  maintenanceStates         PlatformMaintenanceState[]

  @@index([status, requestedAt])
  @@index([requestedAt, id])
  @@index([backupOperationId, requestedAt])
  @@index([requestedById, requestedAt])
  @@map("restore_operations")
}

model PlatformMaintenanceState {
  id                 String                   @id @default(uuid()) @db.Uuid
  singletonKey       Int                      @default(1)
  enabled            Boolean                  @default(false)
  mode               PlatformMaintenanceMode?
  reason             String?                  @db.VarChar(500)
  restoreOperationId String?                  @db.Uuid
  enabledById        String?                  @db.Uuid
  disabledById       String?                  @db.Uuid
  enabledAt          DateTime?                @db.Timestamptz(3)
  disabledAt         DateTime?                @db.Timestamptz(3)
  restartRequiredAt  DateTime?                @db.Timestamptz(3)
  createdAt          DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime                 @updatedAt @db.Timestamptz(3)

  restoreOperation RestoreOperation? @relation(fields: [restoreOperationId], references: [id], onDelete: Restrict)
  enabledBy        User?             @relation("MaintenanceEnabledBy", fields: [enabledById], references: [id], onDelete: Restrict)
  disabledBy       User?             @relation("MaintenanceDisabledBy", fields: [disabledById], references: [id], onDelete: Restrict)

  @@unique([singletonKey])
  @@index([enabled, mode])
  @@index([restoreOperationId])
  @@map("platform_maintenance_state")
}
