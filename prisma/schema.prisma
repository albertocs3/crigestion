generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InstallationStatus {
  NOT_INITIALIZED
  INITIALIZING
  INITIALIZED
  FAILED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum BackupOperationStatus {
  REQUESTED
  RUNNING
  VERIFIED
  FAILED
}

enum RestoreOperationStatus {
  REQUESTED
  VALIDATING
  VALIDATED
  PREPARING
  RESTORING
  VERIFYING
  COMPLETED
  FAILED
  REQUIRES_RECOVERY
}

enum PlatformMaintenanceMode {
  RESTORE
}

enum AttachmentPurpose {
  COMPANY_LOGO
}

enum AttachmentStatus {
  PENDING_VALIDATION
  SCANNING
  AVAILABLE
  REJECTED
  REPLACED
  RETENTION_LOCKED
  PHYSICALLY_DELETED
}

enum AttachmentScanResult {
  PENDING
  CLEAN
  INFECTED
  INCONCLUSIVE
}

enum CustomerType {
  COMPANY
  SELF_EMPLOYED
  INDIVIDUAL
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum SupplierPaymentMethod {
  BANK_TRANSFER
  CASH
  DIRECT_DEBIT
}

enum SupplierPaymentTermsType {
  IMMEDIATE
  DAYS
  FIXED_DAY_OF_MONTH
}

enum PurchaseInvoiceStatus {
  DRAFT
  REGISTERED
  RECTIFIED
  VOIDED
}

enum PurchaseInvoiceDocumentType {
  STANDARD
  RECTIFICATION
}

enum PurchasePaymentStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  NOT_APPLICABLE
}

enum PurchaseDueDateStatus {
  PENDING
  PAID
  CANCELLED
}

enum SupplierPaymentStatus {
  POSTED
  VOIDED
}

enum PurchaseVatRecordStatus {
  ACTIVE
  REVERSED
}

enum CustomerFiscalTreatment {
  DOMESTIC
  EU
  EXPORT
  CANARY_CEUTA_MELILLA
}

enum CustomerPaymentMethod {
  BANK_TRANSFER
  CASH
  DIRECT_DEBIT
}

enum CustomerPaymentTermsType {
  IMMEDIATE
  DAYS
  FIXED_DAY_OF_MONTH
}

enum CustomerSepaMandateStatus {
  ACTIVE
  REVOKED
  INVALIDATED
}

enum CustomerAddressType {
  BILLING
  SHIPPING
  OTHER
}

enum CustomerAddressStatus {
  ACTIVE
  INACTIVE
}

enum CatalogItemKind {
  PRODUCT
  SERVICE
  SOFTWARE
  LICENSE
}

enum CatalogItemStatus {
  ACTIVE
  INACTIVE
}

enum CatalogCategoryStatus {
  ACTIVE
  INACTIVE
}

enum CatalogTaxRateStatus {
  ACTIVE
  INACTIVE
}

enum CatalogStockMovementType {
  ADJUSTMENT
  PURCHASE_RECEIPT
  PURCHASE_RETURN
}

enum CustomerStoreStatus {
  ACTIVE
  INACTIVE
}

enum InvoiceDocumentType {
  STANDARD
  RECTIFICATION
}

enum InvoiceDocumentStatus {
  DRAFT
  ISSUED
  RECTIFIED
  VOIDED
}

enum InvoicePaymentStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  PARTIALLY_SETTLED
  SETTLED
  NOT_APPLICABLE
  UNPAID
  CANCELLED
}

enum InvoiceVerifactuStatus {
  NOT_APPLICABLE
  PENDING
  SENT
  ACCEPTED
  ACCEPTED_WITH_ERRORS
  REJECTED
  CANCELLED
}

enum VerifactuEnvironment {
  TEST
  PRODUCTION
}

enum VerifactuSifStatus {
  ACTIVE
  RETIRED
}

enum VerifactuRecordType {
  ALTA
  ANULACION
}

enum VerifactuAttemptKind {
  SUBMIT
  RECONCILE
}

enum VerifactuAttemptOutcome {
  ACCEPTED
  ACCEPTED_WITH_ERRORS
  REJECTED
  RETRYABLE_FAILURE
  UNKNOWN
}

enum VerifactuOutboxStatus {
  PENDING
  CLAIMED
  PROCESSED
  DEAD
}

enum VerifactuWorkerStatus {
  RUNNING
  STOPPING
  STOPPED
  FAILED
}

enum VerifactuMtlsCredentialStatus {
  ACTIVE
  DISABLED
  REVOKED
}

enum VerifactuMtlsCredentialVersionStatus {
  STAGED
  TESTED
  ACTIVE
  RETIRED
  REVOKED
}

enum VerifactuMtlsTestOutcome {
  RUNNING
  PASSED
  FAILED
  UNKNOWN
}

enum VerifactuMtlsEndpointKind {
  STANDARD
  SEAL
}

enum InvoiceOrigin {
  MANUAL
  SUBSCRIPTION
}

enum InvoiceDueDateStatus {
  PENDING
  PAID
  SETTLED
  RETURNED
  UNPAID
  CANCELLED
}

enum CustomerPaymentSource {
  MANUAL
  SEPA_REMITTANCE
}

enum CustomerRemittanceStatus {
  DRAFT
  GENERATED
  SENT
  REJECTED
  PARTIALLY_PROCESSED
  PROCESSED
  PARTIALLY_RETURNED
  CLOSED
  CANCELLED
}

enum CustomerRemittanceLineStatus {
  ACTIVE
  CANCELLED
}

enum BankAccountStatus {
  ACTIVE
  INACTIVE
}

enum BankMovementSource {
  MANUAL
  NORMA43
}

enum BankStatementFormat {
  AEB43_2012
}

enum BankReconciliationStatus {
  ACTIVE
  UNDONE
}

enum AccountingAccountStatus {
  ACTIVE
  INACTIVE
}

enum AccountingFiscalYearStatus {
  OPEN
  CLOSED
}

enum AccountingEntryOrigin {
  MANUAL
  INVOICE
  INVOICE_VOIDING
  PURCHASE_INVOICE
  PURCHASE_RECTIFICATION
  SUPPLIER_PAYMENT
  CUSTOMER_PAYMENT
  CUSTOMER_PAYMENT_RETURN
  CUSTOMER_CREDIT_REFUND
  REGULARIZATION
  CLOSING
  OPENING
}

enum CustomerCreditRefundStatus {
  REQUESTED
  APPROVED
  POSTED
  CANCELLED
}

enum AccountingEntryStatus {
  POSTED
  VOIDED
}

model Installation {
  id                     String             @id @default(uuid()) @db.Uuid
  singletonKey           Int                @default(1)
  status                 InstallationStatus @default(NOT_INITIALIZED)
  startedAt              DateTime?          @db.Timestamptz(3)
  completedAt            DateTime?          @db.Timestamptz(3)
  productVersion         String             @db.VarChar(32)
  failureCode            String?            @db.VarChar(100)
  companyId              String?            @unique @db.Uuid
  initialAdministratorId String?            @unique @db.Uuid
  createdAt              DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime           @updatedAt @db.Timestamptz(3)

  company              Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)
  initialAdministrator User?    @relation(fields: [initialAdministratorId], references: [id], onDelete: Restrict)

  @@unique([singletonKey])
  @@map("installations")
}

model Company {
  id                     String   @id @default(uuid()) @db.Uuid
  logoAttachmentId       String?  @unique @db.Uuid
  legalName              String   @db.VarChar(200)
  taxId                  String   @unique @db.VarChar(32)
  email                  String?  @db.VarChar(254)
  bankIban               String?  @db.VarChar(34)
  sepaCreditorIdentifier String?  @db.VarChar(35)
  createdAt              DateTime @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime @updatedAt @db.Timestamptz(3)

  installation             Installation?
  accountingFiscalYears    AccountingFiscalYear[]
  bankAccounts             BankAccount[]
  bankStatements           BankStatement[]
  invoices                 Invoice[]
  purchaseInvoices         PurchaseInvoice[]
  purchaseVatRecords       PurchaseVatRecord[]
  supplierPayments         SupplierPayment[]
  customerCredits          CustomerCredit[]
  customerCreditRefunds    CustomerCreditRefund[]
  verifactuInstallations   VerifactuSifInstallation[]
  verifactuFiscalRecords   VerifactuFiscalRecord[]
  verifactuMtlsCredentials VerifactuMtlsCredential[]
  verifactuWorkerRuns      VerifactuWorkerRun[]
  attachments              Attachment[]               @relation("CompanyAttachments")
  suppliers                Supplier[]
  logoAttachment           Attachment?                @relation("CompanyLogo", fields: [logoAttachmentId], references: [id], onDelete: Restrict)

  @@map("companies")
}

model Attachment {
  id                   String               @id @default(uuid()) @db.Uuid
  companyId            String               @db.Uuid
  purpose              AttachmentPurpose
  originalFileName     String               @db.VarChar(255)
  description          String?              @db.VarChar(500)
  extension            String               @db.VarChar(10)
  declaredMimeType     String               @db.VarChar(100)
  detectedMimeType     String?              @db.VarChar(100)
  sizeBytes            BigInt
  sha256               String?              @db.Char(64)
  storageKey           String?              @unique @db.VarChar(500)
  status               AttachmentStatus     @default(PENDING_VALIDATION)
  scanResult           AttachmentScanResult @default(PENDING)
  scanEngine           String?              @db.VarChar(80)
  scanEngineVersion    String?              @db.VarChar(80)
  scanCompletedAt      DateTime?            @db.Timestamptz(3)
  rejectionCode        String?              @db.VarChar(100)
  availableAt          DateTime?            @db.Timestamptz(3)
  replacedAt           DateTime?            @db.Timestamptz(3)
  physicallyDeletedAt  DateTime?            @db.Timestamptz(3)
  replacesAttachmentId String?              @db.Uuid
  uploadedById         String               @db.Uuid
  uploadedAt           DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime             @updatedAt @db.Timestamptz(3)

  company     Company     @relation("CompanyAttachments", fields: [companyId], references: [id], onDelete: Restrict)
  logoCompany Company?    @relation("CompanyLogo")
  uploadedBy  User        @relation("AttachmentsUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)
  replaces    Attachment? @relation("AttachmentReplacement", fields: [replacesAttachmentId, companyId], references: [id, companyId], onDelete: Restrict)
  replacedBy  Attachment? @relation("AttachmentReplacement")

  @@unique([id, companyId])
  @@unique([replacesAttachmentId, companyId])
  @@index([companyId, purpose, status, uploadedAt, id])
  @@index([uploadedById, uploadedAt, id])
  @@index([sha256])
  @@map("attachments")
}

model Customer {
  id                   String                   @id @default(uuid()) @db.Uuid
  code                 String                   @unique @db.VarChar(20)
  type                 CustomerType
  status               CustomerStatus           @default(ACTIVE)
  legalName            String                   @db.VarChar(200)
  tradeName            String?                  @db.VarChar(160)
  taxId                String                   @db.VarChar(32)
  normalizedTaxId      String                   @unique @db.VarChar(64)
  fiscalTreatment      CustomerFiscalTreatment
  email                String?                  @db.VarChar(254)
  phone                String?                  @db.VarChar(40)
  fiscalAddressLine    String                   @db.VarChar(240)
  fiscalPostalCode     String                   @db.VarChar(20)
  fiscalCity           String                   @db.VarChar(120)
  fiscalProvince       String?                  @db.VarChar(120)
  fiscalCountry        String                   @db.VarChar(2)
  defaultPaymentMethod CustomerPaymentMethod    @default(BANK_TRANSFER)
  paymentTermsType     CustomerPaymentTermsType @default(IMMEDIATE)
  paymentDays          Int?
  paymentFixedDay      Int?
  creditLimit          Decimal?                 @db.Decimal(12, 2)
  bankIban             String?                  @db.VarChar(34)
  notes                String?                  @db.VarChar(1000)
  createdById          String                   @db.Uuid
  updatedById          String?                  @db.Uuid
  createdAt            DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime                 @updatedAt @db.Timestamptz(3)

  createdBy       User                     @relation("CustomersCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy       User?                    @relation("CustomersUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  addresses       CustomerAddress[]
  stores          CustomerStore[]
  sepaMandates    CustomerSepaMandate[]
  remittanceLines CustomerRemittanceLine[]
  invoices        Invoice[]
  credits         CustomerCredit[]
  creditRefunds   CustomerCreditRefund[]

  @@index([status, legalName, id])
  @@index([createdAt, id])
  @@index([createdById, createdAt])
  @@map("customers")
}

model Supplier {
  id                   String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId            String                   @db.Uuid
  sequenceNumber       Int
  code                 String                   @db.VarChar(20)
  accountingCode       String                   @db.VarChar(9)
  status               SupplierStatus           @default(ACTIVE)
  legalName            String                   @db.VarChar(200)
  tradeName            String?                  @db.VarChar(160)
  taxIdEncrypted       Bytes                    @db.ByteA
  taxIdLookupHash      String                   @db.Char(64)
  taxIdLast4           String                   @db.VarChar(4)
  fiscalAddressLine    String                   @db.VarChar(240)
  fiscalPostalCode     String                   @db.VarChar(20)
  fiscalCity           String                   @db.VarChar(120)
  fiscalProvince       String?                  @db.VarChar(120)
  fiscalCountry        String                   @db.VarChar(2)
  contactName          String?                  @db.VarChar(160)
  emailEncrypted       Bytes?                   @db.ByteA
  phoneEncrypted       Bytes?                   @db.ByteA
  bankIbanEncrypted    Bytes?                   @db.ByteA
  bankIbanLast4        String?                  @db.VarChar(4)
  bankBicEncrypted     Bytes?                   @db.ByteA
  defaultPaymentMethod SupplierPaymentMethod    @default(BANK_TRANSFER)
  paymentTermsType     SupplierPaymentTermsType @default(IMMEDIATE)
  paymentDays          Int?
  paymentFixedDay      Int?
  notes                String?                  @db.VarChar(1000)
  createdById          String                   @db.Uuid
  updatedById          String?                  @db.Uuid
  version              Int                      @default(1)
  createdAt            DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime                 @updatedAt @db.Timestamptz(3)

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  createdBy          User                @relation("SuppliersCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy          User?               @relation("SuppliersUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  accounts           AccountingAccount[]
  purchaseInvoices   PurchaseInvoice[]
  purchaseVatRecords PurchaseVatRecord[]
  supplierPayments   SupplierPayment[]

  @@unique([companyId, sequenceNumber])
  @@unique([companyId, code])
  @@unique([companyId, taxIdLookupHash])
  @@unique([id, accountingCode])
  @@index([companyId, status, legalName, id])
  @@index([companyId, createdAt, id])
  @@index([createdById, createdAt])
  @@map("suppliers")
}

model PurchaseInvoice {
  id                              String                @id @default(uuid()) @db.Uuid
  companyId                       String                @db.Uuid
  supplierId                      String                @db.Uuid
  supplierCodeSnapshot            String                @db.VarChar(20)
  supplierAccountingCodeSnapshot  String                @db.VarChar(9)
  supplierLegalNameSnapshot       String                @db.VarChar(200)
  supplierTaxIdLast4Snapshot      String                @db.VarChar(4)
  supplierTaxIdEncryptedSnapshot  Bytes                 @db.ByteA
  supplierInvoiceNumber           String                @db.VarChar(80)
  supplierInvoiceNumberNormalized String                @db.VarChar(80)
  documentType                    PurchaseInvoiceDocumentType @default(STANDARD)
  status                          PurchaseInvoiceStatus @default(DRAFT)
  paymentStatus                   PurchasePaymentStatus @default(PENDING)
  issueDate                       DateTime              @db.Date
  receivedDate                    DateTime              @db.Date
  operationDate                   DateTime              @db.Date
  accountingDate                  DateTime              @db.Date
  subtotal                        Decimal               @default(0) @db.Decimal(14, 2)
  discountTotal                   Decimal               @default(0) @db.Decimal(14, 2)
  taxableBase                     Decimal               @default(0) @db.Decimal(14, 2)
  taxAmount                       Decimal               @default(0) @db.Decimal(14, 2)
  total                           Decimal               @default(0) @db.Decimal(14, 2)
  notes                           String?               @db.VarChar(1000)
  rectificationReason             String?               @db.VarChar(120)
  rectifiesPurchaseInvoiceId      String?               @db.Uuid
  version                         Int                   @default(1)
  createdById                     String                @db.Uuid
  updatedById                     String?               @db.Uuid
  registeredById                  String?               @db.Uuid
  registeredAt                    DateTime?             @db.Timestamptz(3)
  createdAt                       DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt                       DateTime              @updatedAt @db.Timestamptz(3)

  company         Company                     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  supplier        Supplier                    @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdBy       User                        @relation("PurchaseInvoicesCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy       User?                       @relation("PurchaseInvoicesUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  registeredBy    User?                       @relation("PurchaseInvoicesRegisteredBy", fields: [registeredById], references: [id], onDelete: Restrict)
  lines           PurchaseInvoiceLine[]
  taxSummaries    PurchaseInvoiceTaxSummary[]
  vatRecords      PurchaseVatRecord[]
  dueDates        PurchaseDueDate[]
  allocations     SupplierPaymentAllocation[]
  accountingEntry AccountingJournalEntry?     @relation("PurchaseInvoiceAccountingEntry")
  rectifiesPurchaseInvoice PurchaseInvoice?   @relation("PurchaseInvoiceRectifications", fields: [rectifiesPurchaseInvoiceId], references: [id], onDelete: Restrict)
  rectificationInvoices   PurchaseInvoice[]    @relation("PurchaseInvoiceRectifications")

  @@unique([companyId, supplierId, supplierInvoiceNumberNormalized])
  @@unique([id, companyId])
  @@index([companyId, status, accountingDate, id])
  @@index([companyId, paymentStatus, accountingDate, id])
  @@index([supplierId, issueDate, id])
  @@index([rectifiesPurchaseInvoiceId])
  @@index([createdById, createdAt, id])
  @@map("purchase_invoices")
}

model PurchaseInvoiceLine {
  id                      String           @id @default(uuid()) @db.Uuid
  purchaseInvoiceId       String           @db.Uuid
  position                Int
  catalogItemId           String?          @db.Uuid
  catalogItemCodeSnapshot String?          @db.VarChar(20)
  catalogItemKindSnapshot CatalogItemKind?
  description             String           @db.VarChar(500)
  quantity                Decimal          @db.Decimal(12, 3)
  unitPrice               Decimal          @db.Decimal(12, 2)
  discountPercent         Decimal          @default(0) @db.Decimal(5, 2)
  discountAmount          Decimal          @default(0) @db.Decimal(12, 2)
  purchaseAccountCode     String           @db.VarChar(9)
  taxRateId               String           @db.Uuid
  taxRateCodeSnapshot     String           @db.VarChar(40)
  taxRateNameSnapshot     String           @db.VarChar(120)
  taxRateSnapshot         Decimal          @db.Decimal(5, 2)
  lineSubtotal            Decimal          @db.Decimal(14, 2)
  lineDiscountTotal       Decimal          @db.Decimal(14, 2)
  lineTaxableBase         Decimal          @db.Decimal(14, 2)
  lineTaxAmount           Decimal          @db.Decimal(14, 2)
  lineTotal               Decimal          @db.Decimal(14, 2)
  createdAt               DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt               DateTime         @updatedAt @db.Timestamptz(3)

  purchaseInvoice PurchaseInvoice       @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Restrict)
  catalogItem     CatalogItem?          @relation(fields: [catalogItemId], references: [id], onDelete: Restrict)
  taxRate         CatalogTaxRate        @relation(fields: [taxRateId], references: [id], onDelete: Restrict)
  stockMovement   CatalogStockMovement?

  @@unique([purchaseInvoiceId, position])
  @@index([catalogItemId])
  @@index([taxRateId])
  @@index([purchaseAccountCode])
  @@map("purchase_invoice_lines")
}

model PurchaseInvoiceTaxSummary {
  id                String  @id @default(uuid()) @db.Uuid
  purchaseInvoiceId String  @db.Uuid
  taxRateCode       String  @db.VarChar(40)
  taxRate           Decimal @db.Decimal(5, 2)
  taxableBase       Decimal @db.Decimal(14, 2)
  taxAmount         Decimal @db.Decimal(14, 2)
  total             Decimal @db.Decimal(14, 2)

  purchaseInvoice PurchaseInvoice    @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Restrict)
  vatRecord       PurchaseVatRecord?

  @@unique([purchaseInvoiceId, taxRateCode, taxRate])
  @@map("purchase_invoice_tax_summaries")
}

model PurchaseVatRecord {
  id                             String                  @id @default(uuid()) @db.Uuid
  companyId                      String                  @db.Uuid
  supplierId                     String                  @db.Uuid
  purchaseInvoiceId              String                  @db.Uuid
  taxSummaryId                   String                  @unique @db.Uuid
  accountingEntryId              String                  @db.Uuid
  status                         PurchaseVatRecordStatus @default(ACTIVE)
  supplierInvoiceNumberSnapshot  String                  @db.VarChar(80)
  supplierCodeSnapshot           String                  @db.VarChar(20)
  supplierLegalNameSnapshot      String                  @db.VarChar(200)
  supplierTaxIdLast4Snapshot     String                  @db.VarChar(4)
  supplierTaxIdEncryptedSnapshot Bytes                   @db.ByteA
  issueDate                      DateTime                @db.Date
  accountingDate                 DateTime                @db.Date
  taxRateCode                    String                  @db.VarChar(40)
  taxRate                        Decimal                 @db.Decimal(5, 2)
  taxableBase                    Decimal                 @db.Decimal(14, 2)
  taxAmount                      Decimal                 @db.Decimal(14, 2)
  total                          Decimal                 @db.Decimal(14, 2)
  createdAt                      DateTime                @default(now()) @db.Timestamptz(3)

  company         Company                   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  supplier        Supplier                  @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  purchaseInvoice PurchaseInvoice           @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Restrict)
  taxSummary      PurchaseInvoiceTaxSummary @relation(fields: [taxSummaryId], references: [id], onDelete: Restrict)
  accountingEntry AccountingJournalEntry    @relation(fields: [accountingEntryId], references: [id], onDelete: Restrict)

  @@index([companyId, status, accountingDate, id])
  @@index([supplierId, issueDate, id])
  @@index([purchaseInvoiceId])
  @@index([accountingEntryId])
  @@map("purchase_vat_records")
}

model PurchaseDueDate {
  id                String                @id @default(uuid()) @db.Uuid
  purchaseInvoiceId String                @db.Uuid
  position          Int
  dueDate           DateTime              @db.Date
  amount            Decimal               @db.Decimal(14, 2)
  paymentMethod     SupplierPaymentMethod
  status            PurchaseDueDateStatus @default(PENDING)
  createdAt         DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime              @updatedAt @db.Timestamptz(3)

  purchaseInvoice PurchaseInvoice             @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Restrict)
  allocations     SupplierPaymentAllocation[]

  @@unique([purchaseInvoiceId, position])
  @@unique([id, purchaseInvoiceId])
  @@index([status, dueDate, id])
  @@index([purchaseInvoiceId, dueDate, id])
  @@map("purchase_due_dates")
}

model SupplierPayment {
  id            String                @id @default(uuid()) @db.Uuid
  companyId     String                @db.Uuid
  supplierId    String                @db.Uuid
  paymentDate   DateTime              @db.Date
  totalAmount   Decimal               @db.Decimal(14, 2)
  paymentMethod SupplierPaymentMethod
  status        SupplierPaymentStatus @default(POSTED)
  reference     String?               @db.VarChar(120)
  notes         String?               @db.VarChar(500)
  createdById   String                @db.Uuid
  createdAt     DateTime              @default(now()) @db.Timestamptz(3)

  company         Company                     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  supplier        Supplier                    @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdBy       User                        @relation("SupplierPaymentsCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  allocations     SupplierPaymentAllocation[]
  accountingEntry AccountingJournalEntry?     @relation("SupplierPaymentAccountingEntry")

  @@unique([id, companyId])
  @@index([companyId, status, paymentDate, id])
  @@index([supplierId, paymentDate, id])
  @@index([createdById, createdAt, id])
  @@map("supplier_payments")
}

model SupplierPaymentAllocation {
  id                String   @id @default(uuid()) @db.Uuid
  supplierPaymentId String   @db.Uuid
  purchaseInvoiceId String   @db.Uuid
  dueDateId         String   @db.Uuid
  amount            Decimal  @db.Decimal(14, 2)
  createdAt         DateTime @default(now()) @db.Timestamptz(3)

  supplierPayment SupplierPayment @relation(fields: [supplierPaymentId], references: [id], onDelete: Restrict)
  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Restrict)
  dueDate         PurchaseDueDate @relation(fields: [dueDateId, purchaseInvoiceId], references: [id, purchaseInvoiceId], onDelete: Restrict)

  @@unique([supplierPaymentId, dueDateId])
  @@index([purchaseInvoiceId, createdAt, id])
  @@index([dueDateId, createdAt, id])
  @@map("supplier_payment_allocations")
}

model CustomerSepaMandate {
  id                  String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId          String                    @db.Uuid
  reference           String                    @db.VarChar(80)
  referenceNormalized String                    @unique @db.VarChar(80)
  status              CustomerSepaMandateStatus @default(ACTIVE)
  signedAt            DateTime                  @db.Date
  revokedAt           DateTime?                 @db.Timestamptz(3)
  createdById         String                    @db.Uuid
  revokedById         String?                   @db.Uuid
  createdAt           DateTime                  @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime                  @updatedAt @db.Timestamptz(3)

  customer        Customer                 @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy       User                     @relation("CustomerSepaMandatesCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  revokedBy       User?                    @relation("CustomerSepaMandatesRevokedBy", fields: [revokedById], references: [id], onDelete: Restrict)
  remittanceLines CustomerRemittanceLine[]

  @@index([customerId, status])
  @@index([createdById, createdAt])
  @@map("customer_sepa_mandates")
}

